{
  "name": "vibecoder-monorepo",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run --workspaces build",
    "typecheck": "npm run --workspaces typecheck",
    "dev:backend": "npm --workspace @vibecoder/backend run dev",
    "build:extension": "npm --workspace @vibecoder/extension run build"
  },
  "dependencies": {
    "@types/axios": "^0.9.36",
    "axios": "^1.14.0"
  }
}
