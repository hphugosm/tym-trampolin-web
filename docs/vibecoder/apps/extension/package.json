{
  "name": "@vibecoder/extension",
  "displayName": "VibeCoder MVP",
  "description": "Local multi-model coding orchestrator extension (MVP)",
  "version": "0.1.0",
  "publisher": "vibecoder",
  "private": true,
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vibecoder.runTask",
        "title": "VibeCoder: Run Task"
      }
    ],
    "configuration": {
      "title": "VibeCoder",
      "properties": {
        "vibecoder.backendUrl": {
          "type": "string",
          "default": "http://127.0.0.1:8787",
          "description": "Base URL of local VibeCoder backend"
        }
      }
    }
  },
  "scripts": {
    "demo": "node demo/server.mjs",
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/vscode": "^1.90.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.2"
  }
}
