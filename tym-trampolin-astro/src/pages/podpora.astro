---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import SectionHeading from '../components/SectionHeading.astro';
import PageNav from '../components/PageNav.astro';
import AsOfDate from '../components/trust/AsOfDate.astro';

const base = import.meta.env.BASE_URL;

const spendingCategories = [
  { label: 'Cestovné a doprava', pct: 30 },
  { label: 'Ubytování', pct: 20 },
  { label: 'Technologie a nástroje', pct: 20 },
  { label: 'Vzdělávání a kurzy', pct: 10 },
  { label: 'Produkce a merch', pct: 10 },
  { label: 'Rozvoj týmu', pct: 10 },
];

const partnerBenefits = ['Logo na webu a materiálech', 'Zmínky na sociálních sítích', 'Přístup k našim projektům', 'Společné PR a média'];
---

<BaseLayout title="Podpora — Tým Trampolín" description="Podpořte studentský tým na průniku politiky, technologií a AI. Transparentní hospodaření, veřejný žebříček podporovatelů.">
  <Navigation active="podpora" />

  <!-- ═══ HERO ═══ -->
  <section class="relative z-10 pt-36 pb-16 px-5 md:px-10">
    <div class="max-w-[80rem] mx-auto">
      <p class="reveal eyebrow mb-4">Každá koruna se počítá</p>
      <h1 class="display-lg text-white mb-8" data-split>
        Podpořte<br/>náš tým
      </h1>
      <p class="reveal reveal-delay-1 text-lg text-[var(--color-text-secondary)] max-w-2xl leading-relaxed">
        Vaše podpora nám umožňuje soutěžit, vzdělávat se a tvořit projekty, které mají smysl. Hospodaříme transparentně — žebříček podporovatelů i rozpad výdajů jsou veřejné.
      </p>
    </div>
  </section>

  <!-- ═══ SUPPORT METHODS ═══ -->
  <section class="relative z-10 rule">
    <div class="max-w-[80rem] mx-auto grid grid-cols-1 md:grid-cols-3">
      <!-- Finanční podpora -->
      <div class="p-8 md:p-10 border-[var(--color-line)]">
        <p class="eyebrow mb-4" style="color: var(--color-gold);">01 — Finančně</p>
        <h3 class="display-sm text-white mb-3">Přímý příspěvek</h3>
        <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed mb-6">
          Příspěvek na účet pomůže pokrýt cestování, technologie a další rozvoj.
        </p>
        <div class="border border-[var(--color-line-strong)] p-4 mb-5">
          <div class="label !text-[0.62rem] text-[var(--color-text-muted)] mb-1.5">Číslo účtu</div>
          <div class="flex items-center gap-2 flex-wrap">
            <code class="text-lg text-white font-[var(--font-mono)] font-bold" id="account-number">2301837719/2010</code>
            <button id="copy-btn" class="p-2 border border-[var(--color-line)] hover:border-[var(--color-brand)] transition-colors text-[var(--color-text-muted)] hover:text-white" aria-label="Kopírovat číslo účtu">
              <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M15.666 3.888A2.25 2.25 0 0013.5 2.25h-3c-1.03 0-1.9.693-2.166 1.638m7.332 0c.055.194.084.4.084.612v0a.75.75 0 01-.75.75H9.75a.75.75 0 01-.75-.75v0c0-.212.03-.418.084-.612m7.332 0c.646.049 1.288.11 1.927.184 1.1.128 1.907 1.077 1.907 2.185V19.5a2.25 2.25 0 01-2.25 2.25H6.75A2.25 2.25 0 014.5 19.5V6.257c0-1.108.806-2.057 1.907-2.185a48.208 48.208 0 011.927-.184"/></svg>
            </button>
          </div>
        </div>
        <div class="media-frame inline-block bg-white p-1.5">
          <img src={`${base}media/support-qr.jpg`} alt="QR kód pro platbu na účet 2301837719/2010" class="w-32 h-32" loading="lazy" />
        </div>
        <p class="label !text-[0.62rem] text-[var(--color-text-muted)] mt-2">Naskenujte QR kód</p>
      </div>

      <!-- Partnerství -->
      <div class="p-8 md:p-10 border-t md:border-t-0 md:border-l border-[var(--color-line)]">
        <p class="eyebrow mb-4">02 — Partnersky</p>
        <h3 class="display-sm text-white mb-3">Partnerství</h3>
        <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed mb-6">
          Pro firmy, školy a média. Nabízíme konkrétní výstupy, ne jen logo v patičce.
        </p>
        <h4 class="label text-[var(--color-text-muted)] mb-3">Co partner získá</h4>
        <ul class="space-y-2 mb-8">
          {partnerBenefits.map(item => (
            <li class="flex items-start gap-3 text-sm text-[var(--color-text-secondary)]">
              <span class="text-[var(--color-brand)] shrink-0 mt-0.5" aria-hidden="true">✳</span>
              {item}
            </li>
          ))}
        </ul>
        <a href={`${base}partnerstvi/`} data-track="partner_cta_click" data-track-meta='{"placement":"podpora"}' class="btn-primary">
          Nabídka partnerství
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>

      <!-- Sdílení -->
      <div class="p-8 md:p-10 border-t md:border-t-0 md:border-l border-[var(--color-line)]">
        <p class="eyebrow mb-4">03 — Sdílením</p>
        <h3 class="display-sm text-white mb-3">Šiřte nás dál</h3>
        <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed mb-6">
          Každé sdílení pomáhá. Sledujte nás a šiřte povědomí o tom, co studenti dokážou.
        </p>
        <div class="flex flex-col gap-3">
          <a href="https://www.instagram.com/tym_trampolin/" target="_blank" rel="noopener noreferrer" class="link-button">
            Instagram — @tym_trampolin
          </a>
          <a href="https://www.twitch.tv/tym_trampolin" target="_blank" rel="noopener noreferrer" class="link-button">
            Twitch — tym_trampolin
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ SPENDING ═══ -->
  <section class="relative z-10 rule py-24 px-5 md:px-10">
    <div class="max-w-[80rem] mx-auto">
      <SectionHeading
        index="01"
        label="Transparentnost"
        title="Kam jdou peníze"
        description="Jsme maximálně transparentní. Tady je přehled, jak využíváme finanční podporu."
        center={false}
      />
      <div class="max-w-3xl space-y-5">
        {spendingCategories.map((cat, i) => (
          <div class={`reveal ${i > 0 ? `reveal-delay-${Math.min(i, 3)}` : ''}`}>
            <div class="flex items-center justify-between mb-2">
              <span class="text-sm font-medium text-white">{cat.label}</span>
              <span class="label text-[var(--color-text-secondary)]">{cat.pct} %</span>
            </div>
            <div class="h-3 bg-[var(--color-ink-3)] border border-[var(--color-line)]">
              <div class="h-full bg-[var(--color-brand)]" style={`width: ${cat.pct}%`}></div>
            </div>
          </div>
        ))}
      </div>
      <div class="mt-6"><AsOfDate /></div>
    </div>
  </section>

  <!-- ═══ LEADERBOARD ═══ -->
  <section class="relative z-10 rule py-24 px-5 md:px-10">
    <div class="max-w-[80rem] mx-auto">
      <SectionHeading
        index="02"
        label="Naši podporovatelé"
        title="Děkujeme všem"
        description="Každého příspěvku si vážíme. Žebříček se načítá živě a aktualizuje každou minutu."
        center={false}
      />
      <div class="max-w-3xl border border-[var(--color-line-strong)] bg-[var(--color-ink-2)] p-6" id="leaderboard">
        <div class="text-center py-8">
          <div class="inline-flex items-center gap-2 label text-[var(--color-text-muted)]">
            <svg class="animate-spin" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 6v6l4 2"/><circle cx="12" cy="12" r="10"/></svg>
            Načítám data podporovatelů…
          </div>
        </div>
      </div>
    </div>
  </section>

  <PageNav cards={[
    {
      href: `${base}partnerstvi/`,
      label: 'Pro firmy',
      title: 'Partnerství',
      desc: 'Konkrétní výstupy pro partnery a sponzory',
    },
    {
      href: `${base}kontakt/`,
      label: 'Kontakt',
      title: 'Napište nám',
      desc: 'Email, telefon nebo sociální sítě',
    }
  ]} />

  <Footer />
</BaseLayout>

<script>
  // Copy account number (+ account_copy tracking hook)
  document.getElementById('copy-btn')?.addEventListener('click', () => {
    const num = document.getElementById('account-number')?.textContent || '';
    navigator.clipboard.writeText(num).then(() => {
      window.__ttTrack?.('account_copy');
      const btn = document.getElementById('copy-btn');
      if (btn) {
        btn.innerHTML = '<svg width="16" height="16" fill="none" stroke="var(--color-emerald)" stroke-width="2" viewBox="0 0 24 24"><path d="M4.5 12.75l6 6 9-13.5"/></svg>';
        setTimeout(() => {
          btn.innerHTML = '<svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M15.666 3.888A2.25 2.25 0 0013.5 2.25h-3c-1.03 0-1.9.693-2.166 1.638m7.332 0c.055.194.084.4.084.612v0a.75.75 0 01-.75.75H9.75a.75.75 0 01-.75-.75v0c0-.212.03-.418.084-.612m7.332 0c.646.049 1.288.11 1.927.184 1.1.128 1.907 1.077 1.907 2.185V19.5a2.25 2.25 0 01-2.25 2.25H6.75A2.25 2.25 0 014.5 19.5V6.257c0-1.108.806-2.057 1.907-2.185a48.208 48.208 0 011.927-.184"/></svg>';
        }, 2000);
      }
    });
  });

  // Escape HTML to avoid XSS from Sheet contents
  function escapeHtml(s: string): string {
    return s
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  // Fetch leaderboard from Google Sheets CSV
  async function loadLeaderboard() {
    const container = document.getElementById('leaderboard');
    if (!container) return;

    try {
      const csvUrl = 'https://docs.google.com/spreadsheets/d/10152ugtcgIstnjHDMo28jNlYtVJKqf9XOdqkBeu-cyQ/export?format=csv&gid=0';
      const resp = await fetch(csvUrl, { cache: 'no-store' });
      if (!resp.ok) throw new Error('fetch failed');
      const text = await resp.text();

      const rows = text.split('\n').slice(1).filter(r => r.trim());
      const donors: { name: string; amount: number }[] = [];

      for (const row of rows) {
        const match = row.match(/^"?([^",]+)"?,\s*"?(\d+)"?/);
        if (match) {
          const name = match[1].trim().slice(0, 64);
          const amount = parseInt(match[2]);
          if (name && !Number.isNaN(amount) && amount >= 0 && amount < 1e8) {
            donors.push({ name, amount });
          }
        }
      }

      donors.sort((a, b) => b.amount - a.amount);

      if (donors.length === 0) {
        container.textContent = '';
        const empty = document.createElement('div');
        empty.className = 'text-center py-8 text-[var(--color-text-muted)]';
        empty.textContent = 'Zatím žádní podporovatelé.';
        container.appendChild(empty);
        return;
      }

      let html = '<div>';
      donors.forEach((d, i) => {
        const isTop = i < 3;
        const rankColor = i === 0 ? 'text-[var(--color-gold)]' : i === 1 ? 'text-gray-300' : i === 2 ? 'text-amber-600' : 'text-[var(--color-text-muted)]';
        html += `
          <div class="flex items-center gap-4 px-3 py-3 ${i > 0 ? 'border-t border-[var(--color-line)]' : ''} hover:bg-white/5 transition-colors">
            <span class="w-10 font-[var(--font-mono)] font-bold ${rankColor} ${isTop ? 'text-lg' : 'text-sm'}">${String(i + 1).padStart(2, '0')}</span>
            <span class="flex-1 text-sm font-medium ${isTop ? 'text-white' : 'text-[var(--color-text-secondary)]'}">${escapeHtml(d.name)}</span>
            <span class="text-sm font-bold font-[var(--font-mono)] ${isTop ? 'text-[var(--color-gold)]' : 'text-[var(--color-text-muted)]'}">${d.amount.toLocaleString('cs-CZ')} Kč</span>
          </div>
        `;
      });
      html += '</div>';

      const total = donors.reduce((s, d) => s + d.amount, 0);
      html += `
        <div class="mt-4 pt-4 border-t-2 border-[var(--color-line-strong)] flex items-center justify-between px-3">
          <span class="label text-[var(--color-text-muted)]">Celkem vybráno</span>
          <span class="stat-num !text-2xl text-[var(--color-gold)]">${total.toLocaleString('cs-CZ')} Kč</span>
        </div>
      `;

      container.innerHTML = html;
    } catch (e) {
      container.textContent = '';
      const err = document.createElement('div');
      err.className = 'text-center py-8 text-[var(--color-text-muted)]';
      err.textContent = 'Nepodařilo se načíst data. Zkuste to později.';
      container.appendChild(err);
    }
  }

  loadLeaderboard();
  setInterval(loadLeaderboard, 60000);
</script>
