---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import SectionHeading from '../components/SectionHeading.astro';
import PageNav from '../components/PageNav.astro';

const base = import.meta.env.BASE_URL;

const contacts = [
  {
    label: 'Email',
    value: 'hugo.kubicek@icloud.com',
    href: 'mailto:hugo.kubicek@icloud.com',
    description: 'Nejrychlejší způsob kontaktu. Odpovíme do 24 hodin.'
  },
  {
    label: 'Telefon',
    value: '+420 731 544 015',
    href: 'tel:+420731544015',
    description: 'Hugo Kubíček — vedoucí týmu'
  },
  {
    label: 'Instagram',
    value: '@tym_trampolin',
    href: 'https://www.instagram.com/tym_trampolin/',
    description: 'Sledujte naše aktivity a zákulisí.'
  },
  {
    label: 'Twitch',
    value: 'tym_trampolin',
    href: 'https://www.twitch.tv/tym_trampolin',
    description: 'Naše live streamy a akce.'
  },
];

const partnerTypes = [
  {
    title: 'Finanční sponzor',
    desc: 'Podpořte nás finančně a získejte viditelnost na všech našich platformách a materiálech.',
  },
  {
    title: 'Mediální partner',
    desc: 'Spolupráce na obsahu, rozhovorech a mediálním pokrytí našich aktivit a soutěží.',
  },
  {
    title: 'Technologický partner',
    desc: 'Poskytněte nástroje, mentoring nebo technologické zázemí pro naše projekty.',
  },
];
---

<BaseLayout title="Kontakt — Tým Trampolín" description="Kontaktujte Tým Trampolín. Spolupráce, partnerství, mediální dotazy.">
  <Navigation active="kontakt" />

  <!-- ═══ HERO ═══ -->
  <section class="relative z-10 pt-36 pb-16 px-5 md:px-10">
    <div class="max-w-[80rem] mx-auto">
      <p class="reveal eyebrow mb-4">Ozvěte se</p>
      <h1 class="display-lg text-white mb-8" data-split>
        Kontakt
      </h1>
      <p class="reveal reveal-delay-1 text-lg text-[var(--color-text-secondary)] max-w-2xl leading-relaxed">
        Ať už hledáte partnerství, chcete napsat článek, nebo jen říct ahoj — jsme tu pro vás.
      </p>
    </div>
  </section>

  <!-- ═══ CONTACT ROWS ═══ -->
  <section class="relative z-10 rule">
    <div class="max-w-[80rem] mx-auto">
      {contacts.map((contact, i) => (
        <a
          href={contact.href}
          target={contact.href.startsWith('http') ? '_blank' : undefined}
          rel={contact.href.startsWith('http') ? 'noopener noreferrer' : undefined}
          class:list={['group grid grid-cols-1 md:grid-cols-[10rem_1fr_auto] items-center gap-2 md:gap-8 px-5 md:px-10 py-8 no-underline hover:bg-[var(--color-ink-2)] transition-colors', i > 0 && 'border-t border-[var(--color-line)]']}
        >
          <span class="eyebrow">{contact.label}</span>
          <span>
            <span class="display-sm text-white group-hover:text-[var(--color-brand-hot)] transition-colors block break-all">{contact.value}</span>
            <span class="text-sm text-[var(--color-text-muted)] mt-1 block">{contact.description}</span>
          </span>
          <svg class="hidden md:block shrink-0 text-[var(--color-text-muted)] group-hover:text-[var(--color-brand)] group-hover:translate-x-2 transition-all duration-300" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      ))}
    </div>
  </section>

  <!-- ═══ PARTNERSHIP TYPES ═══ -->
  <section class="relative z-10 rule py-24">
    <div class="max-w-[80rem] mx-auto px-5 md:px-10">
      <SectionHeading
        index="01"
        label="Spolupráce"
        title="Možnosti partnerství"
        description="Nabízíme různé formy partnerství. Najdeme společně to, co dává smysl pro vás i pro nás."
        center={false}
      />
    </div>
    <div class="rule">
      <div class="max-w-[80rem] mx-auto grid grid-cols-1 md:grid-cols-3">
        {partnerTypes.map((type, i) => (
          <div class:list={['reveal group p-8 md:p-10 border-[var(--color-line)] hover:bg-[var(--color-ink-2)] transition-colors', i > 0 && 'border-t md:border-t-0 md:border-l', i > 0 && `reveal-delay-${i}`]}>
            <div class="label text-[var(--color-text-muted)] mb-5">0{i + 1}</div>
            <h3 class="display-sm !text-xl text-white mb-3 group-hover:text-[var(--color-brand-hot)] transition-colors">{type.title}</h3>
            <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">{type.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ CTA ═══ -->
  <section class="relative z-10 rule-strong bg-[var(--color-brand)] text-[var(--color-ink)]">
    <div class="max-w-[80rem] mx-auto px-5 md:px-10 py-20">
      <h2 class="display-md mb-5" data-split>Připraveni na společný projekt?</h2>
      <p class="max-w-lg text-[var(--color-ink)]/75 leading-relaxed mb-8">
        Napište nám e-mail nebo zavolejte. Rádi se potkáme osobně i online a probereme možnosti spolupráce.
      </p>
      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
        <a href="mailto:hugo.kubicek@icloud.com" class="magnetic inline-flex items-center gap-2.5 bg-[var(--color-ink)] text-white border-2 border-[var(--color-ink)] px-8 py-4 font-[var(--font-mono)] text-[0.8125rem] font-semibold uppercase tracking-[0.12em] no-underline transition-transform hover:-translate-y-0.5" data-magnetic="10">
          Napsat e-mail
        </a>
        <a href="tel:+420731544015" class="magnetic inline-flex items-center gap-2.5 bg-transparent text-[var(--color-ink)] border-2 border-[var(--color-ink)]/50 hover:border-[var(--color-ink)] px-8 py-4 font-[var(--font-mono)] text-[0.8125rem] font-semibold uppercase tracking-[0.12em] no-underline transition-all hover:-translate-y-0.5" data-magnetic="8">
          Zavolat
        </a>
      </div>
      <p class="label text-[var(--color-ink)]/60 mt-10">
        Gymnázium Amazon &bull; Praha &bull; Česká republika
      </p>
    </div>
  </section>

  <PageNav cards={[
    {
      href: `${base}podpora/`,
      label: 'Partnerství',
      title: 'Podpořte nás',
      desc: 'Finanční i mediální formy spolupráce',
    },
    {
      href: `${base}psali-o-nas/`,
      label: 'Média',
      title: 'Psali o nás',
      desc: 'Mediální zmínky a press kit',
    }
  ]} />

  <Footer />
</BaseLayout>
