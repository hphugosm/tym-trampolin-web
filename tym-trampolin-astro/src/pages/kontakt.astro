---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import PageNav from '../components/PageNav.astro';

const base = import.meta.env.BASE_URL;

const contacts = [
  {
    icon: '<svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>',
    label: 'Email',
    value: 'hugo.kubicek@icloud.com',
    href: 'mailto:hugo.kubicek@icloud.com',
    description: 'Nejrychlejší způsob kontaktu. Odpovíme do 24 hodin.'
  },
  {
    icon: '<svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>',
    label: 'Telefon',
    value: '+420 731 544 015',
    href: 'tel:+420731544015',
    description: 'Hugo Kubíček — vedoucí týmu'
  },
  {
    icon: '<svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>',
    label: 'Instagram',
    value: '@tym_trampolin',
    href: 'https://www.instagram.com/tym_trampolin/',
    description: 'Sledujte naše aktivity a zákulisí.'
  },
  {
    icon: '<svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24"><path d="M11.571 4.714h1.715v5.143H11.57zm4.715 0H18v5.143h-1.714zM6 0L1.714 4.286v15.428h5.143V24l4.286-4.286h3.428L22.286 12V0zm14.571 11.143l-3.428 3.428h-3.429l-3 3v-3H6.857V1.714h13.714z"/></svg>',
    label: 'Twitch',
    value: 'tym_trampolin',
    href: 'https://www.twitch.tv/tym_trampolin',
    description: 'Naše live streamy a akce.'
  },
];

const partnerTypes = [
  {
    title: 'Finanční sponzor',
    desc: 'Podpořte nás finančně a získejte viditelnost na všech našich platformách a materiálech.',
    icon: '<svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>'
  },
  {
    title: 'Mediální partner',
    desc: 'Spolupráce na obsahu, rozhovorech a mediálním pokrytí našich aktivit a soutěží.',
    icon: '<svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M12 7.5h1.5m-1.5 3h1.5m-7.5 3h7.5m-7.5 3h7.5m3-9h3.375c.621 0 1.125.504 1.125 1.125V18a2.25 2.25 0 01-2.25 2.25M16.5 7.5V4.875c0-.621-.504-1.125-1.125-1.125H4.125C3.504 3.75 3 4.254 3 4.875V18a2.25 2.25 0 002.25 2.25h13.5M6 7.5h3v3H6v-3z"/></svg>'
  },
  {
    title: 'Technologický partner',
    desc: 'Poskytněte nástroje, mentoring nebo technologické zázemí pro naše projekty.',
    icon: '<svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M14.25 9.75L16.5 12l-2.25 2.25m-4.5 0L7.5 12l2.25-2.25M6 20.25h12A2.25 2.25 0 0020.25 18V6A2.25 2.25 0 0018 3.75H6A2.25 2.25 0 003.75 6v12A2.25 2.25 0 006 20.25z"/></svg>'
  },
];
---

<BaseLayout title="Kontakt — Tým Trampolín" description="Kontaktujte Tým Trampolín. Spolupráce, partnerství, mediální dotazy.">
  <Navigation active="kontakt" />

  <!-- HERO -->
  <section class="relative z-10 pt-32 pb-16 px-6 min-h-[500px] overflow-hidden" style={`background: linear-gradient(rgba(8, 18, 40, 0.70), rgba(8, 18, 40, 0.70)), url('${base}media/IMG_7891.jpg'); background-size: cover; background-position: center; background-attachment: fixed; filter: brightness(0.8) saturate(0.6) contrast(1.1);`}>
    <div class="max-w-4xl mx-auto text-center">
      <h1 class="reveal text-4xl md:text-6xl font-bold tracking-tight mb-6">
        Kontaktujte <span class="text-gradient">nás</span>
      </h1>
      <p class="reveal reveal-delay-1 text-lg text-[var(--color-text-secondary)] max-w-2xl mx-auto leading-relaxed">
        Ať už hledáte partnerství, chcete napsat článek, nebo jen říct ahoj — jsme tu pro vás.
      </p>
    </div>
  </section>

  <!-- CONTACT CARDS -->
  <section class="relative z-10 py-16 px-6">
    <div class="max-w-4xl mx-auto">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {contacts.map((contact, i) => (
          <a
            href={contact.href}
            target={contact.href.startsWith('http') ? '_blank' : undefined}
            rel={contact.href.startsWith('http') ? 'noopener noreferrer' : undefined}
            class={`reveal ${i > 0 ? `reveal-delay-${i}` : ''} tilt-3d glass p-6 rounded-2xl hover:border-[var(--color-accent)]/30 transition-colors duration-300 group block no-underline relative`}
          >
            <div class="flex items-start gap-4">
              <div class="shrink-0 w-11 h-11 rounded-xl bg-[var(--color-accent)]/10 flex items-center justify-center text-[var(--color-accent-bright)] group-hover:scale-110 transition-transform" set:html={contact.icon} />
              <div>
                <div class="text-xs text-[var(--color-text-muted)] uppercase tracking-wider mb-1">{contact.label}</div>
                <div class="text-base font-semibold text-white group-hover:text-[var(--color-accent-bright)] transition-colors mb-1">{contact.value}</div>
                <p class="text-xs text-[var(--color-text-secondary)]">{contact.description}</p>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- PARTNERSHIP TYPES -->
  <section class="relative z-10 py-24 px-6">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-white mb-4">Možnosti <span class="text-gradient">spolupráce</span></h2>
        <p class="text-[var(--color-text-secondary)] max-w-xl mx-auto">
          Nabízíme různé formy partnerství. Najdeme společně to, co dává smysl pro vás i pro nás.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {partnerTypes.map((type, i) => (
          <div class={`reveal ${i > 0 ? `reveal-delay-${i}` : ''} tilt-3d glass p-6 rounded-2xl text-center hover:border-[var(--color-accent)]/20 transition-colors duration-300 relative`}>
            <div class="w-12 h-12 mx-auto rounded-xl bg-[var(--color-accent)]/10 flex items-center justify-center text-[var(--color-accent-bright)] mb-4" set:html={type.icon} />
            <h3 class="text-base font-bold text-white mb-2">{type.title}</h3>
            <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">{type.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative z-10 py-24 px-6">
    <div class="max-w-3xl mx-auto">
      <div class="reveal glass-strong p-10 md:p-14 rounded-2xl text-center">
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-4">
          Připraveni na <span class="text-gradient">společný projekt?</span>
        </h2>
        <p class="text-[var(--color-text-secondary)] max-w-lg mx-auto leading-relaxed mb-8">
          Napište nám e-mail nebo zavolejte. Rádi se potkáme osobně i online a probereme možnosti spolupráce.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="mailto:hugo.kubicek@icloud.com" class="magnetic btn-primary px-8 py-3.5" data-magnetic="14">
            Napsat e-mail
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
          </a>
          <a href="tel:+420731544015" class="magnetic btn-outline px-8 py-3.5" data-magnetic="10">
            Zavolat
          </a>
        </div>

        <div class="mt-8">
          <p class="text-xs text-[var(--color-text-muted)]">
            Gymnázium Amazon &bull; Praha &bull; Česká republika
          </p>
        </div>
      </div>
    </div>
  </section>

  <PageNav cards={[
    {
      href: `${base}podpora/`,
      label: 'Partnerství',
      title: 'Podpořte nás',
      desc: 'Finanční i mediální formy spolupráce',
      icon: '<svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"/></svg>'
    },
    {
      href: `${base}psali-o-nas/`,
      label: 'Média',
      title: 'Psali o nás',
      desc: 'Mediální zmínky a ohlasy na náš tým',
      icon: '<svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M12 7.5h1.5m-1.5 3h1.5m-7.5 3h7.5m-7.5 3h7.5m3-9h3.375c.621 0 1.125.504 1.125 1.125V18a2.25 2.25 0 01-2.25 2.25M16.5 7.5V4.875c0-.621-.504-1.125-1.125-1.125H4.125C3.504 3.75 3 4.254 3 4.875V18a2.25 2.25 0 002.25 2.25h13.5M6 7.5h3v3H6v-3z"/></svg>'
    }
  ]} />

  <Footer />
</BaseLayout>
