---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import Panel from '../../components/dashboard/Panel.astro';
import Kpi from '../../components/dashboard/Kpi.astro';
import Heatmap from '../../components/dashboard/Heatmap.astro';
import StatusPill from '../../components/dashboard/StatusPill.astro';
import { MOCK_GITHUB as g } from '../../data/dashboard/mock';

const fmt = (iso: string) => new Date(iso).toLocaleString('cs-CZ', { day: '2-digit', month: '2-digit', hour: '2-digit', minute: '2-digit' });
---
<DashboardLayout title="GitHub" active="github">
  <div class="dash-grid">
    <Kpi label="Commity (30 dní)" value={g.commits30d} accent="violet" spark={g.commitsByDay.map(d=>d.count)} />
    <Kpi label="Stars" value={g.stars} accent="gold" />
    <Kpi label="Forks" value={g.forks} accent="cyan" />
    <Kpi label="Otevřené issues" value={g.openIssues} accent="rose" />

    <Panel title="Aktivita commitů" eyebrow="17 týdnů" accent="violet" source={g.meta.source} note={g.meta.note} span={4}>
      <Heatmap data={g.commitsByDay} accent="violet" />
    </Panel>

    <Panel title="Poslední workflow běhy" eyebrow="Deploy" accent="violet" source={g.meta.source} span={2}>
      <ul class="flex flex-col">
        {g.recentRuns.map((r, i) => (
          <li class:list={['flex items-center justify-between gap-3 py-2.5', i>0 && 'border-t border-[var(--color-line)]']}>
            <div class="min-w-0"><div class="text-sm text-white truncate">{r.name}</div><div class="dash-mono text-[10px] text-[var(--color-text-muted)]">{fmt(r.at)}</div></div>
            <StatusPill status={r.status} />
          </li>
        ))}
      </ul>
    </Panel>

    <Panel title="Poslední deploy" eyebrow="Stav" accent="emerald" source={g.meta.source} span={2}>
      <div class="flex items-center gap-3 mb-3"><StatusPill status={g.lastDeploy.status} /><span class="dash-mono text-sm text-[var(--color-text-secondary)]">{g.lastDeploy.sha}</span></div>
      <p class="dash-muted text-sm">{fmt(g.lastDeploy.at)}</p>
      <p class="dash-muted text-xs mt-4">Přispěvatelé: <span class="text-white dash-mono">{g.contributors}</span></p>
    </Panel>
  </div>
</DashboardLayout>
