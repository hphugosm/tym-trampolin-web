---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import Panel from '../../components/dashboard/Panel.astro';
import { MOCK_LOGS as l } from '../../data/dashboard/mock';

const fmt = (iso: string) => new Date(iso).toLocaleString('cs-CZ', { day: '2-digit', month: '2-digit', hour: '2-digit', minute: '2-digit' });
const sevColor: Record<string, string> = { ok: 'var(--color-emerald)', info: 'var(--color-brand)', warn: 'var(--color-gold)', error: 'var(--color-rose)' };
---
<DashboardLayout title="Logy & Aktivita" active="logs">
  <Panel title="Sjednocený stream" eyebrow="Deploy · události · chyby" accent="muted" source={l.meta.source} note={l.meta.note} span={4}>
    <ul class="flex flex-col">
      {l.entries.map((e, i) => (
        <li class:list={['flex items-start gap-3 py-2.5', i>0 && 'border-t border-[var(--color-line)]']}>
          <span class="dash-mono text-[10px] text-[var(--color-text-muted)] w-24 shrink-0 pt-0.5">{fmt(e.at)}</span>
          <span class="dash-mono text-[0.58rem] uppercase px-1.5 py-0.5 border shrink-0" style={`color:${sevColor[e.severity]}; border-color:${sevColor[e.severity]};`}>{e.source}</span>
          <span class="text-sm text-[var(--color-text-secondary)]">{e.text}</span>
        </li>
      ))}
    </ul>
  </Panel>
</DashboardLayout>
