---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import Panel from '../../components/dashboard/Panel.astro';
import Gauge from '../../components/dashboard/Gauge.astro';
import Donut from '../../components/dashboard/Donut.astro';
import TrendChart from '../../components/dashboard/TrendChart.astro';
import { MOCK_AI as a } from '../../data/dashboard/mock';

const fmt = (iso: string) => new Date(iso).toLocaleDateString('cs-CZ', { day: '2-digit', month: '2-digit' });
const remaining = a.higgsfieldCreditsTotal - a.higgsfieldCreditsUsed;
---
<DashboardLayout title="AI Usage" active="ai">
  <div class="dash-grid">
    <Panel title="AI náklady tento měsíc" eyebrow="Z financí" accent="violet" source="live" span={2}>
      <div data-fill="aicost"><p class="dash-muted text-sm">Načítám z ledgeru…</p></div>
    </Panel>
    <Panel title="AI náklady — celkem" eyebrow="Ledger" accent="violet" source="live" span={2} bodyClass="flex flex-col justify-center">
      <div class="dash-kpi-num" data-k="aitotal" style="font-size:2rem;">—</div>
      <div class="dash-kpi-label">za tento měsíc (kategorie AI / provider)</div>
      <a href="finance/" class="link-button mt-3 !text-[0.7rem]">Spravovat v ledgeru →</a>
    </Panel>

    <Panel title="Higgsfield kredity" eyebrow="Zbývá" accent="violet" source={a.meta.source} note={a.meta.note} span={2} bodyClass="flex flex-col items-center">
      <Gauge value={remaining} max={a.higgsfieldCreditsTotal} accent="violet" label={`zbývá z ${a.higgsfieldCreditsTotal}`} />
      <p class="dash-muted text-xs mt-2">Spotřebováno: <span class="text-white dash-mono">{a.higgsfieldCreditsUsed}</span></p>
    </Panel>

    <Panel title="Generace podle typu" eyebrow="Produkce" accent="violet" source={a.meta.source} span={2}>
      <Donut items={a.byType} />
    </Panel>

    <Panel title="Náklady po měsících" eyebrow="Kredity" accent="violet" source={a.meta.source} span={2}>
      <TrendChart data={a.spendByMonth} accent="violet" />
    </Panel>

    <Panel title="Poslední generace" eyebrow="Log" accent="violet" source={a.meta.source} span={2}>
      <ul class="flex flex-col">
        {a.recent.map((r, i) => (
          <li class:list={['py-2.5', i>0 && 'border-t border-[var(--color-line)]']}>
            <div class="flex items-center gap-2"><span class="dash-mono text-[0.6rem] uppercase px-1.5 py-0.5 border border-[var(--color-line)] text-[var(--color-accent-2)]">{r.kind}</span><span class="text-sm text-[var(--color-text-secondary)] truncate">{r.detail}</span></div>
            <div class="dash-mono text-[10px] text-[var(--color-text-muted)] mt-1">{fmt(r.at)}</div>
          </li>
        ))}
      </ul>
    </Panel>
  </div>

  <script>
    import { supabaseRepository } from '../../features/finance/repository';
    import { aiCostsByProvider, fmtCZK } from '../../features/finance/service';

    async function render() {
      try {
        const txs = await supabaseRepository.list();
        const byProvider = aiCostsByProvider(txs);
        const total = byProvider.reduce((s, p) => s + p.value, 0);
        const totalEl = document.querySelector('[data-k="aitotal"]');
        if (totalEl) totalEl.textContent = fmtCZK(total);
        const box = document.querySelector('[data-fill="aicost"]');
        if (box) {
          box.innerHTML = byProvider.length
            ? byProvider.map((p) => {
                const max = Math.max(...byProvider.map((x) => x.value)) || 1;
                return `<div class="mb-2.5"><div class="flex justify-between mb-1"><span class="text-sm text-[var(--color-text-secondary)]">${p.label}</span><span class="dash-mono text-sm text-white">${fmtCZK(p.value)}</span></div><div class="dash-bar-track"><div class="dash-bar-fill" style="width:${Math.round((p.value / max) * 100)}%;background:${p.accent || 'var(--color-accent-2)'};"></div></div></div>`;
              }).join('')
            : '<p class="dash-muted text-sm">Zatím žádné AI náklady — přidej je v ledgeru (kategorie AI).</p>';
        }
      } catch (e) {
        if ((e as Error).message === 'unauthorized') document.dispatchEvent(new Event('tt:authfail'));
      }
    }
    render();
    document.addEventListener('tt:auth', render);
    document.addEventListener('astro:page-load', render);
  </script>
</DashboardLayout>
