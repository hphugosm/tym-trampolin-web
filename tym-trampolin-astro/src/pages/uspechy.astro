---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import SectionHeading from '../components/SectionHeading.astro';
import PageNav from '../components/PageNav.astro';

const base = import.meta.env.BASE_URL;

const galleryImages = [
  { src: `${base}media/finale-stage-1.webp`, alt: 'Finále DemocraTICon — na pódiu' },
  { src: `${base}media/team-trio.webp`, alt: 'Tým Trampolín — trojice' },
  { src: `${base}media/team-consultation.webp`, alt: 'Konzultace před vystoupením' },
  { src: `${base}media/team-coding.webp`, alt: 'Programování projektu' },
  { src: `${base}media/workshop-education.webp`, alt: 'Vzdělávací workshop' },
  { src: `${base}media/historical-costumes.webp`, alt: 'Historické kostýmy' },
  // Nové fotky z finále 2026
  { src: `${base}media/IMG_7547.jpg`, alt: 'Fotka z finále — moment' },
  { src: `${base}media/IMG_7552.jpg`, alt: 'Fotka z finále — atmosféra' },
  { src: `${base}media/IMG_7554.jpg`, alt: 'Fotka z finále — tým' },
  { src: `${base}media/IMG_7615.jpg`, alt: 'Fotka z finále — prezentace' },
  { src: `${base}media/IMG_7666.jpg`, alt: 'Fotka z finále — diskuze' },
  { src: `${base}media/IMG_7783.jpg`, alt: 'Fotka z finále DemocraTICon' },
  { src: `${base}media/IMG_7802.jpg`, alt: 'Fotka z finále — tým na pódiu' },
  { src: `${base}media/IMG_7888.jpg`, alt: 'Fotka z finále — finalisté' },
  { src: `${base}media/IMG_7891.jpg`, alt: 'Fotka z finále — okamžik' },
  { src: `${base}media/IMG_7892.jpg`, alt: 'Fotka z finále — soustředění' },
  { src: `${base}media/IMG_7895.jpg`, alt: 'Fotka z finále — energie' },
  { src: `${base}media/IMG_8001.jpg`, alt: 'Fotka z finále — tým DemocraTICon' },
  { src: `${base}media/IMG_8005.jpg`, alt: 'Fotka z finále — Prague event' },
  { src: `${base}media/IMG_8059.jpg`, alt: 'Fotka z finále — setkání' },
  { src: `${base}media/IMG_8060.jpg`, alt: 'Fotka z finále — slavnostní moment' },
];

const projects = [
  {
    title: 'DemocraTICon 2026',
    category: 'Soutěž',
    categoryColor: 'bg-[var(--color-gold)]/15 text-[var(--color-gold)]',
    description: 'Národní soutěž o demokracii a občanství pořádaná organizací Člověk v tísni a JSNS. 318 zaregistrovaných týmů, 14 finalistů. Téma: mezinárodní právo, pluralita a respekt.',
    result: '3. místo v ČR',
    tech: ['Prezentace', 'Výzkum', 'Týmová práce', 'Argumentace'],
    link: null,
    featured: true
  },
  {
    title: 'Kilometry Jdeš',
    category: 'Hra',
    categoryColor: 'bg-rose-400/15 text-rose-300',
    description: 'Endless runner inspirovaný hrou Geometry Dash. Plně funkční herní engine s fyzikou, power-upy, systémem skinů, žebříčkem a 11 hudebními stopami.',
    result: 'Canvas 2D engine od nuly',
    tech: ['JavaScript', 'Canvas 2D', 'WebAudio API', 'Physics Engine'],
    link: `${base}kilometry-jdes.html`,
    featured: false
  },
  {
    title: 'DOOM Bounce',
    category: 'Hra',
    categoryColor: 'bg-rose-400/15 text-rose-300',
    description: 'First-person shooter s raycasting renderem inspirovaný původním DOOMem. Procedurálně generované mapy, 4 typy nepřátel a boss se dvěma fázemi.',
    result: 'Raycasting FPS engine',
    tech: ['JavaScript', 'Canvas 2D', 'Raycasting', 'Procedural Generation'],
    link: `${base}tym_trampolin_doom.html`,
    featured: false
  },
  {
    title: 'Digitální album',
    category: 'Hudba',
    categoryColor: 'bg-violet-400/15 text-violet-300',
    description: 'Týmová hymna v 10 žánrových verzích (phonk, hardstyle, tribe, epic, hooligans). Vlastní imerzivní přehrávač s vizuálními efekty sladěnými s rytmem.',
    result: '10 skladeb + vizuální přehrávač',
    tech: ['WebAudio API', 'AnalyserNode', 'CSS Animations', 'Beat Detection'],
    link: `${base}music/`,
    featured: false
  },
  {
    title: 'E-shop',
    category: 'E-commerce',
    categoryColor: 'bg-emerald-400/15 text-emerald-300',
    description: 'Plnohodnotný merchandisový obchod s košíkem, promokódy, zvukovými efekty, objednávkovým systémem a náhledy herních skinů generovanými na canvasu.',
    result: '11 produktů, plný checkout',
    tech: ['JavaScript', 'localStorage', 'WebAudio', 'Canvas'],
    link: null,
    featured: false
  },
  {
    title: 'Elbot Microlearning',
    category: 'Vzdělávání',
    categoryColor: 'bg-cyan-400/15 text-cyan-300',
    description: 'Interaktivní mikrokurz o občanství a demokracii vytvořený na platformě Elbot. Dostupné vzdělávání pro širší publikum.',
    result: 'Veřejně dostupný kurz',
    tech: ['Elbot', 'Microlearning', 'Vzdělávací design'],
    link: 'https://www.elbot.cz/v2/course/67e98bfb-52ca-424f-a8fd-e8ab59bebc39',
    featured: false
  },
  {
    title: 'Analytický systém',
    category: 'Backend',
    categoryColor: 'bg-amber-400/15 text-amber-300',
    description: 'Vlastní analytický engine s event trackingem, identifikací návštěvníka a relace, bezpečnostní sanitizací a backendem v Google Apps Script.',
    result: 'Custom analytics pipeline',
    tech: ['Google Apps Script', 'Google Sheets', 'REST API', 'Privacy'],
    link: null,
    featured: false
  }
];

const videos = [
  { id: 'VIDEO_ID_1', title: 'Mezinárodní právo — náš pohled' },
  { id: 'VIDEO_ID_2', title: 'Pluralita a respekt v digitální době' },
];
---

<BaseLayout title="Úspěchy — Tým Trampolín" description="Naše projekty a úspěchy. 3. místo DemocraTICon 2026, dvě originální hry, hudební album a další.">
  <Navigation active="uspechy" />

  <!-- ═══ HERO ═══ -->
  <section class="relative z-10 pt-32 pb-16 px-6 min-h-[500px] overflow-hidden" style={`background: linear-gradient(rgba(8, 18, 40, 0.70), rgba(8, 18, 40, 0.70)), url('${base}media/IMG_8005_new.jpg'); background-size: cover; background-position: center; background-attachment: fixed; filter: brightness(0.8) saturate(0.6) contrast(1.1);`}>
    <div class="max-w-4xl mx-auto text-center">
      <div class="reveal inline-flex items-center gap-2 px-4 py-2 rounded-full glass mb-6">
        <span class="text-xs font-medium text-[var(--color-gold)]">3. místo v ČR</span>
      </div>
      <h1 class="reveal text-4xl md:text-6xl font-bold tracking-tight mb-6">
        Naše <span class="text-gradient">úspěchy</span>
      </h1>
      <p class="reveal reveal-delay-1 text-lg text-[var(--color-text-secondary)] max-w-2xl mx-auto leading-relaxed">
        Každý projekt je důkazem, že studenti mohou tvořit na profesionální úrovni. Vše od nuly, bez šablon.
      </p>
    </div>
  </section>

  <!-- ═══ FEATURED: DemocraTICon ═══ -->
  <section class="relative z-10 py-16 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="reveal glass-strong rounded-2xl overflow-hidden">
        <div class="grid grid-cols-1 lg:grid-cols-2">
          <!-- Image side -->
          <div class="h-64 lg:h-auto bg-gradient-to-br from-[var(--color-accent)]/10 to-[var(--color-accent-2)]/10 relative overflow-hidden">
            <img
              src={`${base}media/finale-stage-1.webp`}
              alt="Finále DemocraTICon 2026"
              class="absolute inset-0 w-full h-full object-cover opacity-70"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-r from-transparent to-[var(--color-bg-deep)]/80 lg:bg-gradient-to-r lg:from-transparent lg:to-[var(--color-panel-strong)]"></div>
            <div class="absolute bottom-4 left-4">
              <span class="px-3 py-1.5 text-xs font-bold uppercase tracking-wider rounded-lg bg-[var(--color-gold)]/20 text-[var(--color-gold)] backdrop-blur-sm">
                3. místo
              </span>
            </div>
          </div>

          <!-- Content side -->
          <div class="p-8 lg:p-12 flex flex-col justify-center">
            <span class="text-xs font-semibold text-[var(--color-accent)] uppercase tracking-wider mb-2">Hlavní úspěch</span>
            <h2 class="text-3xl font-bold text-white mb-4">DemocraTICon 2026</h2>
            <p class="text-[var(--color-text-secondary)] leading-relaxed mb-6">
              Národní soutěž o demokracii a občanství. Z <strong class="text-white">318 týmů</strong> z celé České republiky jsme se probojovali mezi <strong class="text-white">14 finalistů</strong> a získali bronzovou medaili. Téma: mezinárodní právo, pluralita a respekt.
            </p>

            <div class="grid grid-cols-3 gap-4 mb-6">
              <div class="text-center p-3 rounded-xl bg-white/5">
                <div class="text-xl font-bold text-white">318</div>
                <div class="text-[0.65rem] text-[var(--color-text-muted)] uppercase tracking-wider">týmů</div>
              </div>
              <div class="text-center p-3 rounded-xl bg-white/5">
                <div class="text-xl font-bold text-white">14</div>
                <div class="text-[0.65rem] text-[var(--color-text-muted)] uppercase tracking-wider">finalistů</div>
              </div>
              <div class="text-center p-3 rounded-xl bg-white/5">
                <div class="text-xl font-bold text-[var(--color-gold)]">3.</div>
                <div class="text-[0.65rem] text-[var(--color-text-muted)] uppercase tracking-wider">místo</div>
              </div>
            </div>

            <div class="text-xs text-[var(--color-text-muted)]">
              Pořadatel: Člověk v tísni &amp; JSNS &bull; Duben 2026 &bull; Praha
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ PROJECTS GRID ═══ -->
  <section class="relative z-10 py-24 px-6">
    <div class="max-w-6xl mx-auto">
      <SectionHeading
        label="Portfolio"
        title='Všechny <span class="text-gradient">projekty</span>'
        description="Kompletní přehled toho, co jsme vytvořili. Každý projekt ukazuje jiný aspekt našich schopností."
      />

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mt-12">
        {projects.filter(p => !p.featured).map((project, i) => (
          <div class={`reveal ${i > 0 ? `reveal-delay-${Math.min(i, 4)}` : ''} tilt-3d glass p-6 rounded-2xl hover:border-[var(--color-accent)]/20 transition-colors duration-300 flex flex-col relative`}>
            <!-- Category badge -->
            <div class="flex items-center gap-2 mb-4">
              <span class={`px-2.5 py-0.5 text-[0.65rem] font-semibold uppercase tracking-wider rounded-full ${project.categoryColor}`}>
                {project.category}
              </span>
            </div>

            <h3 class="text-lg font-bold text-white mb-2">{project.title}</h3>
            <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed mb-4 flex-1">{project.description}</p>

            <!-- Result highlight -->
            <div class="px-3 py-2 rounded-lg bg-white/5 text-sm text-[var(--color-accent)] font-medium mb-4">
              {project.result}
            </div>

            <!-- Tech tags -->
            <div class="flex flex-wrap gap-1.5 mb-4">
              {project.tech.map((t) => (
                <span class="px-2 py-0.5 text-[0.6rem] rounded bg-white/5 text-[var(--color-text-muted)] font-mono">{t}</span>
              ))}
            </div>

            {project.link && (
              <a href={project.link} class="link-button mt-auto">
                Otevřít
                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ GALLERY ═══ -->
  <section class="relative z-10 py-24 px-6">
    <div class="max-w-6xl mx-auto">
      <SectionHeading
        label="Galerie"
        title='Fotky z <span class="text-gradient">finále</span>'
        description="Atmosféra finále DemocraTICon 2026 v Praze."
      />

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mt-12" id="gallery-grid">
        {galleryImages.map((img, i) => (
          <button
            type="button"
            class={`reveal ${i > 0 ? `reveal-delay-${Math.min(i, 4)}` : ''} gallery-item rounded-2xl overflow-hidden aspect-[4/3] relative group text-left cursor-zoom-in border border-[var(--color-line)] hover:border-[var(--color-accent)]/30 transition-colors`}
            data-src={img.src}
            data-alt={img.alt}
            data-index={i}
            aria-label={`Zobrazit: ${img.alt}`}
          >
            <img
              src={img.src}
              alt={img.alt}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-colors duration-300" aria-hidden="true"></div>
            <div class="absolute top-3 right-3 w-8 h-8 rounded-full bg-black/40 backdrop-blur flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity" aria-hidden="true">
              <svg width="14" height="14" fill="none" stroke="white" stroke-width="2" viewBox="0 0 24 24"><path d="M21 21l-4.35-4.35M11 19a8 8 0 100-16 8 8 0 000 16zM11 8v6M8 11h6"/></svg>
            </div>
          </button>
        ))}
      </div>

      <!-- Lightbox -->
      <div id="lightbox" class="fixed inset-0 z-[90] hidden items-center justify-center bg-black/90 backdrop-blur-md p-4" role="dialog" aria-modal="true" aria-label="Náhled fotky">
        <button id="lb-close" class="absolute top-4 right-4 w-11 h-11 rounded-full bg-white/10 hover:bg-white/20 text-white flex items-center justify-center" aria-label="Zavřít">
          <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24"><path d="M6 6l12 12M18 6L6 18"/></svg>
        </button>
        <button id="lb-prev" class="absolute left-4 top-1/2 -translate-y-1/2 w-11 h-11 rounded-full bg-white/10 hover:bg-white/20 text-white flex items-center justify-center" aria-label="Předchozí">
          <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24"><path d="M15 6l-6 6 6 6"/></svg>
        </button>
        <button id="lb-next" class="absolute right-4 top-1/2 -translate-y-1/2 w-11 h-11 rounded-full bg-white/10 hover:bg-white/20 text-white flex items-center justify-center" aria-label="Další">
          <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24"><path d="M9 6l6 6-6 6"/></svg>
        </button>
        <figure class="max-w-5xl max-h-[86vh] w-full flex flex-col items-center justify-center">
          <img id="lb-image" src="" alt="" class="max-h-[80vh] max-w-full rounded-xl shadow-2xl" />
          <figcaption id="lb-caption" class="mt-4 text-sm text-white/80"></figcaption>
        </figure>
      </div>
    </div>
  </section>

  <PageNav cards={[
    {
      href: `${base}o-tymu/`,
      label: 'Náš tým',
      title: 'Kdo za tím stojí',
      desc: 'Hugo, Dan, Vojta — tři studenti Gymnázia Amazon',
      icon: '<svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z"/></svg>'
    },
    {
      href: `${base}kontakt/`,
      label: 'Spolupráce',
      title: 'Kontaktujte nás',
      desc: 'Partnerství, mediální dotazy nebo jen ahoj',
      icon: '<svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>'
    }
  ]} />

  <Footer />

  <script>
    // Lightbox
    (function () {
      const items = Array.from(document.querySelectorAll<HTMLButtonElement>('.gallery-item'));
      const lb = document.getElementById('lightbox');
      const img = document.getElementById('lb-image') as HTMLImageElement | null;
      const cap = document.getElementById('lb-caption');
      const close = document.getElementById('lb-close');
      const prev = document.getElementById('lb-prev');
      const next = document.getElementById('lb-next');
      if (!items.length || !lb || !img || !close || !prev || !next) return;
      let idx = 0;

      function show(i: number) {
        idx = (i + items.length) % items.length;
        const it = items[idx];
        img!.src = it.dataset.src || '';
        img!.alt = it.dataset.alt || '';
        if (cap) cap.textContent = it.dataset.alt || '';
      }
      function open(i: number) {
        show(i);
        lb!.classList.remove('hidden');
        lb!.classList.add('flex');
        document.body.style.overflow = 'hidden';
      }
      function hide() {
        lb!.classList.add('hidden');
        lb!.classList.remove('flex');
        document.body.style.overflow = '';
      }
      items.forEach((it, i) => it.addEventListener('click', () => open(i)));
      close.addEventListener('click', hide);
      prev.addEventListener('click', () => show(idx - 1));
      next.addEventListener('click', () => show(idx + 1));
      lb.addEventListener('click', (e) => { if (e.target === lb) hide(); });
      document.addEventListener('keydown', (e) => {
        if (lb!.classList.contains('hidden')) return;
        if (e.key === 'Escape') hide();
        if (e.key === 'ArrowLeft') show(idx - 1);
        if (e.key === 'ArrowRight') show(idx + 1);
      });
    })();
  </script>
</BaseLayout>
