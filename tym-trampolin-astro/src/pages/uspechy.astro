---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import SectionHeading from '../components/SectionHeading.astro';
import PageNav from '../components/PageNav.astro';

const base = import.meta.env.BASE_URL;

const teaserImages = Object.entries(
  import.meta.glob<{ default: ImageMetadata }>('../assets/images/gallery/*.jpg', { eager: true })
)
  .sort(([a], [b]) => a.localeCompare(b))
  .slice(0, 4)
  .map(([, m]) => m.default);

const stages = [
  {
    num: '318',
    label: 'týmů na startu',
    desc: 'Říjen 2025. Do národní soutěže o demokracii a občanství se registruje 318 týmů z celé České republiky. My jsme jedním z nich — a máme plán nedělat jen prezentace.',
  },
  {
    num: '14',
    label: 'finalistů',
    desc: 'Březen 2026. Tři kola úkolů, výzkumu a argumentace. Kolem soutěže stavíme celý ekosystém: web, hry, hudbu, e-shop. Probojovali jsme se mezi 14 nejlepších.',
  },
  {
    num: '3.',
    label: 'místo v ČR',
    desc: 'Duben 2026, finále v Praze. Téma: mezinárodní právo a pluralita. Bronzová medaile — a hlavně důkaz, že studenti dokážou tvořit na profesionální úrovni.',
    gold: true,
  },
];
---

<BaseLayout title="Úspěchy — Tým Trampolín" description="3. místo DemocraTICon 2026 z 318 týmů. Příběh naší cesty soutěží — od registrace po finále v Praze.">
  <Navigation active="uspechy" />

  <!-- ═══ HERO ═══ -->
  <section class="relative overflow-hidden bg-[var(--color-ink)]">
    <div class="relative pt-36 pb-16 px-5 md:px-10 z-10">
      <div class="max-w-[80rem] mx-auto">
        <p class="reveal eyebrow mb-4" style="color: var(--color-gold);">DemocraTICon 2026 — bronz</p>
        <h1 class="display-lg text-white mb-8" data-split>
          Naše<br/>úspěchy
        </h1>
        <p class="reveal reveal-delay-1 text-lg text-[var(--color-text-secondary)] max-w-2xl leading-relaxed">
          Každý projekt je důkazem, že studenti mohou tvořit na profesionální úrovni. Tohle je příběh soutěže, která nás definovala.
        </p>
      </div>
    </div>
    <div class="relative media-frame !border-x-0 !rounded-none cut-diagonal">
      <img src={`${base}media/finale-stage-1.webp`} alt="Tým Trampolín na pódiu finále DemocraTICon 2026" loading="eager" fetchpriority="high" class="w-full h-[40vh] md:h-[55vh] object-cover scroll-parallax" style="object-position: center 30%;" />
    </div>
  </section>

  <!-- ═══ STORY — 318 → 14 → 3. ═══ -->
  <section class="relative z-10 py-24">
    <div class="max-w-[80rem] mx-auto px-5 md:px-10">
      <SectionHeading index="01" label="Cesta soutěží" title="318 → 14 → 3." center={false} />
    </div>
    <div class="rule">
      {stages.map((stage, i) => (
        <div class:list={['border-[var(--color-line)]', i > 0 && 'border-t']}>
          <div class="max-w-[80rem] mx-auto px-5 md:px-10 py-14 md:py-20 grid grid-cols-1 md:grid-cols-[1fr_1.4fr] gap-8 items-center scroll-fade-scale">
            <div class:list={['stat-num !text-[clamp(5rem,14vw,12rem)]', stage.gold ? 'text-[var(--color-gold)]' : 'num-outline']} style={stage.gold ? '' : '-webkit-text-stroke-color: var(--color-line-strong);'}>
              {stage.num}
            </div>
            <div>
              <p class="label text-[var(--color-brand)] mb-3">{stage.label}</p>
              <p class="text-lg text-[var(--color-text-secondary)] leading-relaxed max-w-xl">{stage.desc}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ═══ FEATURED CARD ═══ -->
  <section class="relative z-10 rule py-24 px-5 md:px-10">
    <div class="max-w-[80rem] mx-auto">
      <div class="reveal grid grid-cols-1 lg:grid-cols-2 border border-[var(--color-line-strong)] overflow-hidden">
        <div class="relative h-72 lg:h-auto overflow-hidden">
          <img
            src={`${base}media/historical-costumes.webp`}
            alt="Historické kostýmy z finálového vystoupení"
            class="absolute inset-0 w-full h-full object-cover"
            loading="lazy"
            style="filter: saturate(0.9);"
          />
        </div>
        <div class="p-8 lg:p-14 bg-[var(--color-ink-2)]">
          <span class="eyebrow mb-4 block" style="color: var(--color-gold);">Hlavní úspěch</span>
          <h2 class="display-md text-white mb-5">DemocraTICon 2026</h2>
          <p class="text-[var(--color-text-secondary)] leading-relaxed mb-8">
            Národní soutěž o demokracii a občanství pořádaná organizací <strong class="text-white">Člověk v tísni</strong> a <strong class="text-white">JSNS</strong>. Porota ocenila, že jsme kolem soutěže postavili celý ekosystém projektů — vše od nuly, bez šablon.
          </p>
          <dl class="grid grid-cols-3 border border-[var(--color-line)] divide-x divide-[var(--color-line)] mb-8">
            {[
              { v: '318', l: 'týmů' },
              { v: '14', l: 'finalistů' },
              { v: '3.', l: 'místo', gold: true },
            ].map((s) => (
              <div class="p-4 text-center">
                <dd class:list={['stat-num !text-3xl', s.gold ? 'text-[var(--color-gold)]' : 'text-white']}>{s.v}</dd>
                <dt class="label !text-[0.6rem] text-[var(--color-text-muted)] mt-1">{s.l}</dt>
              </div>
            ))}
          </dl>
          <p class="label text-[var(--color-text-muted)]">
            Pořadatel: Člověk v tísni &amp; JSNS &bull; Duben 2026 &bull; Praha
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ PROJECTS LINK ═══ -->
  <section class="relative z-10 rule py-20 px-5 md:px-10">
    <div class="max-w-[80rem] mx-auto flex flex-col md:flex-row md:items-center justify-between gap-8">
      <div>
        <p class="eyebrow mb-3">Portfolio</p>
        <h2 class="display-md text-white mb-3">Co všechno jsme postavili</h2>
        <p class="text-[var(--color-text-secondary)] max-w-lg">
          Hry s vlastním enginem, digitální album, e-shop, fyzické artefakty i analytický systém — kompletní přehled na stránce projektů.
        </p>
      </div>
      <a href={`${base}projekty/`} class="btn-primary shrink-0">
        Všechny projekty
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </section>

  <!-- ═══ GALLERY TEASER ═══ -->
  <section class="relative z-10 rule py-24 px-5 md:px-10">
    <div class="max-w-[80rem] mx-auto">
      <SectionHeading
        index="02"
        label="Galerie"
        title="Fotky z finále"
        description="Atmosféra finále DemocraTICon 2026 v Praze."
        center={false}
      />
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
        {teaserImages.map((img, i) => (
          <a href={`${base}galerie/`} class:list={['reveal media-frame block group', i > 0 && `reveal-delay-${Math.min(i, 3)}`]}>
            <Image
              src={img}
              alt={`Fotka z finále DemocraTICon 2026 (${i + 1})`}
              widths={[420, 800]}
              sizes="(max-width: 1024px) 46vw, 23vw"
              format="webp"
              quality={78}
              class="w-full aspect-[4/3] object-cover group-hover:scale-[1.03] transition-transform duration-500"
              loading="lazy"
            />
          </a>
        ))}
      </div>
      <div class="mt-10">
        <a href={`${base}galerie/`} class="link-button">
          Celá galerie
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <PageNav cards={[
    {
      href: `${base}o-tymu/`,
      label: 'Náš tým',
      title: 'Kdo za tím stojí',
      desc: 'Hugo, Dan, Vojta — tři studenti Gymnázia Amazon',
    },
    {
      href: `${base}kontakt/`,
      label: 'Spolupráce',
      title: 'Kontaktujte nás',
      desc: 'Partnerství, mediální dotazy nebo jen ahoj',
    }
  ]} />

  <Footer />
</BaseLayout>
