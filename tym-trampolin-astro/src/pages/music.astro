---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import SectionHeading from '../components/SectionHeading.astro';
import PageNav from '../components/PageNav.astro';

const base = import.meta.env.BASE_URL;

const brandGrad = 'from-[#4fc8ff] to-[#7d8bff]';
const tracks = [
  { id: 'original', title: 'Hymna TT', subtitle: 'Original', genre: 'original', file: `${base}media/album/original.mp3`, color: brandGrad },
  { id: 'phonk1', title: 'Hymna TT', subtitle: 'Phonk I', genre: 'phonk', file: `${base}media/album/phonk1.mp3`, color: brandGrad },
  { id: 'phonk2', title: 'Hymna TT', subtitle: 'Phonk II', genre: 'phonk', file: `${base}media/album/phonk2.mp3`, color: brandGrad },
  { id: 'hardstyle1', title: 'Hymna TT', subtitle: 'Hardstyle I', genre: 'hardstyle', file: `${base}media/album/hardstyle1.mp3`, color: brandGrad },
  { id: 'hardstyle2', title: 'Hymna TT', subtitle: 'Hardstyle II', genre: 'hardstyle', file: `${base}media/album/hardstyle2.mp3`, color: brandGrad },
  { id: 'hooligans', title: 'Hymna TT', subtitle: 'Hooligans', genre: 'hooligans', file: `${base}media/album/hooligans.mp3`, color: brandGrad },
  { id: 'tribe1', title: 'Hymna TT', subtitle: 'Tribe I', genre: 'tribe', file: `${base}media/album/tribe1.mp3`, color: brandGrad },
  { id: 'tribe2', title: 'Hymna TT', subtitle: 'Tribe II', genre: 'tribe', file: `${base}media/album/tribe2.mp3`, color: brandGrad },
  { id: 'epic1', title: 'Hymna TT', subtitle: 'Epic I', genre: 'epic', file: `${base}media/album/epic1.mp3`, color: brandGrad },
  { id: 'epic2', title: 'Hymna TT', subtitle: 'Epic II', genre: 'epic', file: `${base}media/album/epic2.mp3`, color: brandGrad },
];
---

<BaseLayout title="Hudba — Tým Trampolín" description="Digitální album Týmu Trampolín. 10 tracků v různých žánrech. Poslouchejte zdarma.">
  <Navigation active="music" />

  <!-- HERO -->
  <section class="relative z-10 pt-36 pb-16 px-5 md:px-10">
    <div class="max-w-[80rem] mx-auto">
      <p class="reveal eyebrow mb-4">10 tracků &bull; 6 žánrů &bull; 1 hymna</p>
      <h1 class="display-lg text-white mb-8" data-split>
        Digitální<br/>album
      </h1>
      <p class="reveal reveal-delay-1 text-lg text-[var(--color-text-secondary)] max-w-2xl leading-relaxed">
        Naše týmová hymna v 10 unikátních žánrových verzích. Od originálu přes phonk a hardstyle až po epickou orchestrální verzi.
      </p>
    </div>
  </section>

  <!-- NOW PLAYING -->
  <section class="relative z-10 rule py-12 px-5 md:px-10">
    <div class="max-w-2xl mx-auto">
      <div class="reveal bg-[var(--color-ink-2)] border-2 border-[var(--color-line-strong)] p-6 relative overflow-hidden" id="player-card">
        <div class="absolute inset-0 opacity-20 transition-all duration-500" id="player-bg"></div>
        <canvas id="visualizer" class="absolute inset-x-0 bottom-0 h-16 w-full pointer-events-none opacity-70" aria-hidden="true"></canvas>

        <div class="relative flex items-center gap-6">
          <!-- Vinyl -->
          <div class="shrink-0 w-20 h-20 rounded-full bg-gradient-to-br from-[var(--color-accent)]/30 to-[var(--color-accent-2)]/30 flex items-center justify-center border-2 border-white/10" id="vinyl">
            <div class="w-6 h-6 rounded-full bg-[var(--color-bg-deep)] border border-white/20"></div>
          </div>

          <div class="flex-1 min-w-0">
            <div class="text-xs text-[var(--color-text-muted)] uppercase tracking-wider mb-1" id="now-genre">---</div>
            <div class="text-lg font-bold text-white truncate" id="now-title">Vyberte track</div>
            <div class="text-sm text-[var(--color-text-secondary)]" id="now-subtitle">---</div>

            <!-- Progress bar -->
            <div class="mt-3 flex items-center gap-3">
              <span class="text-xs text-[var(--color-text-muted)] font-mono w-10" id="time-current">0:00</span>
              <div class="flex-1 h-1.5 rounded-full bg-white/10 cursor-pointer relative group" id="progress-bar">
                <div class="h-full rounded-full bg-gradient-to-r from-[var(--color-accent)] to-[var(--color-accent-2)] transition-all" id="progress-fill" style="width: 0%"></div>
                <div class="absolute top-1/2 -translate-y-1/2 w-3 h-3 rounded-full bg-white shadow-lg opacity-0 group-hover:opacity-100 transition-opacity" id="progress-thumb" style="left: 0%"></div>
              </div>
              <span class="text-xs text-[var(--color-text-muted)] font-mono w-10 text-right" id="time-total">0:00</span>
            </div>
          </div>
        </div>

        <!-- Controls -->
        <div class="relative flex items-center justify-center gap-4 mt-5">
          <button id="btn-prev" class="w-10 h-10 rounded-xl bg-white/5 hover:bg-white/10 flex items-center justify-center text-white transition-colors" aria-label="Předchozí">
            <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M9.195 18.44c1.25.713 2.805-.19 2.805-1.629v-2.34l6.945 3.968c1.25.714 2.805-.188 2.805-1.628V7.19c0-1.44-1.555-2.342-2.805-1.628L12 9.53V7.19c0-1.44-1.555-2.342-2.805-1.628l-6.945 3.97c-1.25.713-1.25 2.522 0 3.236l6.945 3.97z"/></svg>
          </button>
          <button id="btn-play" class="w-14 h-14 rounded-2xl bg-gradient-to-br from-[var(--color-accent)] to-[var(--color-accent-2)] hover:scale-105 flex items-center justify-center text-white transition-transform shadow-lg shadow-[var(--color-accent-glow)]" aria-label="Play/Pause">
            <svg id="icon-play" width="24" height="24" fill="currentColor" viewBox="0 0 24 24"><path d="M5.25 5.653c0-.856.917-1.398 1.667-.986l11.54 6.348a1.125 1.125 0 010 1.971l-11.54 6.347a1.125 1.125 0 01-1.667-.985V5.653z"/></svg>
            <svg id="icon-pause" width="24" height="24" fill="currentColor" viewBox="0 0 24 24" class="hidden"><path d="M6.75 5.25a.75.75 0 01.75-.75H9a.75.75 0 01.75.75v13.5a.75.75 0 01-.75.75H7.5a.75.75 0 01-.75-.75V5.25zm7.5 0A.75.75 0 0115 4.5h1.5a.75.75 0 01.75.75v13.5a.75.75 0 01-.75.75H15a.75.75 0 01-.75-.75V5.25z"/></svg>
          </button>
          <button id="btn-next" class="w-10 h-10 rounded-xl bg-white/5 hover:bg-white/10 flex items-center justify-center text-white transition-colors" aria-label="Další">
            <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M5.055 7.06c-1.25-.714-2.805.189-2.805 1.628v9.62c0 1.44 1.555 2.342 2.805 1.628L12 16.47v2.342c0 1.44 1.555 2.342 2.805 1.628l6.945-3.97c1.25-.715 1.25-2.523 0-3.237L14.805 9.26c-1.25-.714-2.805.189-2.805 1.628v2.342L5.055 9.26z" transform="translate(0,0)"/></svg>
          </button>
        </div>
      </div>
    </div>
  </section>

  <!-- TRACK LIST -->
  <section class="relative z-10 py-16 px-5 md:px-10">
    <div class="max-w-4xl mx-auto">
      <SectionHeading
        index="01"
        label="Tracklist"
        title="Všechny tracky"
        center={false}
      />

      <div class="border border-[var(--color-line)]" id="track-list">
        {tracks.map((track, i) => (
          <button
            class:list={['track-item w-full flex items-center gap-4 p-4 transition-colors duration-200 hover:bg-[var(--color-ink-2)] text-left group', i > 0 && 'border-t border-[var(--color-line)]']}
            data-index={i}
            data-genre={track.genre}
            data-title={track.title}
            data-subtitle={track.subtitle}
            data-src={track.file}
            data-color={track.color}
          >
            <div class="w-8 text-center">
              <span class="track-number text-sm text-[var(--color-text-muted)] font-mono group-hover:hidden">{String(i + 1).padStart(2, '0')}</span>
              <svg class="track-play-icon hidden group-hover:block mx-auto" width="16" height="16" fill="var(--color-accent-bright)" viewBox="0 0 24 24"><path d="M5.25 5.653c0-.856.917-1.398 1.667-.986l11.54 6.348a1.125 1.125 0 010 1.971l-11.54 6.347a1.125 1.125 0 01-1.667-.985V5.653z"/></svg>
            </div>
            <div class={`w-10 h-10 bg-gradient-to-br ${track.color} opacity-70 flex items-center justify-center shrink-0`}>
              <svg width="16" height="16" fill="white" viewBox="0 0 24 24"><path d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3"/></svg>
            </div>
            <div class="flex-1 min-w-0">
              <div class="text-sm font-semibold text-white truncate">{track.subtitle}</div>
            </div>
            <span class="label !text-[0.62rem] text-[var(--color-text-muted)] px-2 py-0.5 border border-[var(--color-line)]">{track.genre}</span>
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- DOWNLOAD -->
  <section class="relative z-10 rule py-20 px-5 md:px-10">
    <div class="max-w-[80rem] mx-auto flex flex-col md:flex-row md:items-center justify-between gap-8">
      <div>
        <h2 class="display-md text-white mb-3">Stáhněte si celé album</h2>
        <p class="text-[var(--color-text-secondary)] max-w-md">
          Všech 10 tracků v jednom ZIP souboru. Zdarma, bez registrace.
        </p>
      </div>
      <a href={`${base}media/album/tym-trampolin-digital-album.zip`} download class="btn-primary shrink-0">
        Stáhnout album (ZIP)
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3"/></svg>
      </a>
    </div>
  </section>

  <PageNav cards={[
    {
      href: `${base}uspechy/`,
      label: 'Portfolio',
      title: 'Všechny projekty',
      desc: 'Hry, e-shop, analytika a soutěžní výsledky',
      icon: '<svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0H3"/></svg>'
    },
    {
      href: `${base}o-tymu/`,
      label: 'Tým',
      title: 'Poznejte nás',
      desc: 'Tři studenti, kteří tvoří Tým Trampolín',
      icon: '<svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z"/></svg>'
    }
  ]} />

  <Footer />
</BaseLayout>

<style>
  .track-item.active {
    background: rgba(94, 187, 255, 0.08);
    border-color: rgba(94, 187, 255, 0.3);
  }
  .track-item.active .track-number {
    color: var(--color-accent-bright);
  }
  #vinyl.spinning {
    animation: spin 4s linear infinite;
  }
  @keyframes spin {
    to { transform: rotate(360deg); }
  }
</style>

<script>
  const audio = new Audio();
  audio.crossOrigin = 'anonymous';
  let currentIndex = -1;
  let isPlaying = false;

  // WebAudio analyser visualizer
  let audioCtx: AudioContext | null = null;
  let analyser: AnalyserNode | null = null;
  let dataArr: Uint8Array | null = null;
  const vizCanvas = document.getElementById('visualizer') as HTMLCanvasElement | null;
  const vizCtx = vizCanvas?.getContext('2d') ?? null;

  function initAnalyser() {
    if (audioCtx) return;
    try {
      const AC = (window.AudioContext || (window as any).webkitAudioContext);
      if (!AC) return;
      audioCtx = new AC();
      const src = audioCtx.createMediaElementSource(audio);
      analyser = audioCtx.createAnalyser();
      analyser.fftSize = 128;
      dataArr = new Uint8Array(analyser.frequencyBinCount);
      src.connect(analyser);
      analyser.connect(audioCtx.destination);
      drawViz();
    } catch (e) {}
  }

  function drawViz() {
    if (!vizCanvas || !vizCtx || !analyser || !dataArr) return;
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    const rect = vizCanvas.getBoundingClientRect();
    if (vizCanvas.width !== rect.width * dpr) {
      vizCanvas.width = rect.width * dpr;
      vizCanvas.height = rect.height * dpr;
    }
    analyser.getByteFrequencyData(dataArr as any);
    vizCtx.clearRect(0, 0, vizCanvas.width, vizCanvas.height);
    const bars = 48;
    const bw = vizCanvas.width / bars;
    for (let i = 0; i < bars; i++) {
      const v = (dataArr[Math.floor((i / bars) * dataArr.length)] || 0) / 255;
      const h = v * vizCanvas.height * 0.95;
      const grad = vizCtx.createLinearGradient(0, vizCanvas.height - h, 0, vizCanvas.height);
      grad.addColorStop(0, 'rgba(127, 214, 255, 0.9)');
      grad.addColorStop(1, 'rgba(125, 139, 255, 0.2)');
      vizCtx.fillStyle = grad;
      vizCtx.fillRect(i * bw + 2, vizCanvas.height - h, bw - 4, h);
    }
    requestAnimationFrame(drawViz);
  }

  const trackItems = document.querySelectorAll('.track-item') as NodeListOf<HTMLButtonElement>;
  const btnPlay = document.getElementById('btn-play')!;
  const btnPrev = document.getElementById('btn-prev')!;
  const btnNext = document.getElementById('btn-next')!;
  const iconPlay = document.getElementById('icon-play')!;
  const iconPause = document.getElementById('icon-pause')!;
  const nowTitle = document.getElementById('now-title')!;
  const nowSubtitle = document.getElementById('now-subtitle')!;
  const nowGenre = document.getElementById('now-genre')!;
  const progressFill = document.getElementById('progress-fill')!;
  const progressThumb = document.getElementById('progress-thumb')!;
  const progressBar = document.getElementById('progress-bar')!;
  const timeCurrent = document.getElementById('time-current')!;
  const timeTotal = document.getElementById('time-total')!;
  const vinyl = document.getElementById('vinyl')!;
  const playerBg = document.getElementById('player-bg')!;

  function formatTime(s: number): string {
    const m = Math.floor(s / 60);
    const sec = Math.floor(s % 60);
    return `${m}:${sec.toString().padStart(2, '0')}`;
  }

  function loadTrack(index: number) {
    if (index < 0 || index >= trackItems.length) return;
    currentIndex = index;

    const item = trackItems[index];
    const src = item.dataset.src!;
    const title = item.dataset.title!;
    const subtitle = item.dataset.subtitle!;
    const genre = item.dataset.genre!;
    const color = item.dataset.color!;

    audio.src = src;
    nowTitle.textContent = title;
    nowSubtitle.textContent = subtitle;
    nowGenre.textContent = genre;

    // Update active state
    trackItems.forEach(t => t.classList.remove('active'));
    item.classList.add('active');

    // Update player background
    playerBg.className = `absolute inset-0 opacity-20 transition-all duration-500 bg-gradient-to-br ${color}`;
  }

  function play() {
    if (currentIndex === -1) loadTrack(0);
    initAnalyser();
    if (audioCtx && audioCtx.state === 'suspended') audioCtx.resume();
    audio.play();
    isPlaying = true;
    iconPlay.classList.add('hidden');
    iconPause.classList.remove('hidden');
    vinyl.classList.add('spinning');
  }

  function pause() {
    audio.pause();
    isPlaying = false;
    iconPlay.classList.remove('hidden');
    iconPause.classList.add('hidden');
    vinyl.classList.remove('spinning');
  }

  function nextTrack() {
    const next = (currentIndex + 1) % trackItems.length;
    loadTrack(next);
    if (isPlaying) play();
  }

  function prevTrack() {
    if (audio.currentTime > 3) {
      audio.currentTime = 0;
      return;
    }
    const prev = (currentIndex - 1 + trackItems.length) % trackItems.length;
    loadTrack(prev);
    if (isPlaying) play();
  }

  // Event listeners
  btnPlay.addEventListener('click', () => isPlaying ? pause() : play());
  btnNext.addEventListener('click', nextTrack);
  btnPrev.addEventListener('click', prevTrack);

  trackItems.forEach((item, i) => {
    item.addEventListener('click', () => {
      if (currentIndex === i && isPlaying) {
        pause();
      } else {
        loadTrack(i);
        play();
      }
    });
  });

  // Progress bar
  audio.addEventListener('timeupdate', () => {
    if (!audio.duration) return;
    const pct = (audio.currentTime / audio.duration) * 100;
    progressFill.style.width = pct + '%';
    progressThumb.style.left = pct + '%';
    timeCurrent.textContent = formatTime(audio.currentTime);
  });

  audio.addEventListener('loadedmetadata', () => {
    timeTotal.textContent = formatTime(audio.duration);
  });

  audio.addEventListener('ended', nextTrack);

  progressBar.addEventListener('click', (e: MouseEvent) => {
    if (!audio.duration) return;
    const rect = progressBar.getBoundingClientRect();
    const pct = (e.clientX - rect.left) / rect.width;
    audio.currentTime = pct * audio.duration;
  });

  // Keyboard controls
  document.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement) return;
    if (e.code === 'Space') { e.preventDefault(); isPlaying ? pause() : play(); }
    if (e.code === 'ArrowRight') nextTrack();
    if (e.code === 'ArrowLeft') prevTrack();
  });
</script>
