---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import PageNav from '../../components/PageNav.astro';
import CaseStudyBlock from '../../components/trust/CaseStudyBlock.astro';
import PolozkaCard from '../../components/PolozkaCard.astro';
import GameEmbed from '../../components/demos/GameEmbed.astro';
import ChatDemo from '../../components/demos/ChatDemo.astro';
import ProductDemo from '../../components/demos/ProductDemo.astro';
import IgEmbed from '../../components/demos/IgEmbed.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const base = import.meta.env.BASE_URL;

// Prev/next zůstává na stejné úrovni: nadřazené karty cyklují mezi sebou,
// pod-stránky mezi sourozenci pod stejným rodičem.
const siblings = (
  await getCollection('projects', ({ data }) =>
    project.data.parent ? data.parent === project.data.parent : !data.parent
  )
).sort((a, b) => a.data.order - b.data.order);
const idx = siblings.findIndex((p) => p.id === project.id);
const next = siblings[(idx + 1) % siblings.length];
const prev = siblings[(idx - 1 + siblings.length) % siblings.length];

const ctaHref = project.data.ctaUrl ?? project.data.link?.href ?? null;
const ctaLabel = project.data.ctaLabel ?? project.data.link?.label ?? null;
const ctaExternal = ctaHref ? ctaHref.startsWith('http') : false;
const linkHref = ctaHref ? (ctaExternal ? ctaHref : `${base}${ctaHref}`) : null;
const isGameLink = ctaHref ? ctaHref.endsWith('.html') : false;

const d = project.data;
const hasCaseStudy = Boolean(
  d.challenge || d.solution || d.outcomeMetrics.length || d.proofLinks.length || d.awards.length || d.sponsorFit.length
);
const proofLinksResolved = d.proofLinks.map((l) => ({
  ...l,
  href: l.href.startsWith('http') ? l.href : `${base}${l.href}`,
}));

// ── Portfolio: sub-položky nadřazeného projektu ──
const resolveHref = (href) => (href ? (href.startsWith('http') ? href : `${base}${href}`) : null);
const polozky = d.polozky.map((p) => ({
  ...p,
  repoHref: p.repoUrl ?? null,
  liveHref: resolveHref(p.liveUrl),
  liveExternal: p.liveUrl ? p.liveUrl.startsWith('http') : false,
  detailHref: p.detailSlug ? `${base}projekty/${p.detailSlug}/` : null,
}));
const flagshipItems = polozky.filter((p) => p.flagship);
const restItems = polozky.filter((p) => !p.flagship);
const hasPolozky = polozky.length > 0;
const techStack = [...new Set(polozky.flatMap((p) => p.stack))];
const demoLabels = {
  chat: 'Chat ukázka',
  hra: 'Hratelná hra',
  video: 'Video',
  ig: 'Instagram',
  produkt: 'Produkt',
  iframe: 'Živá ukázka',
};

// „Jak to funguje" — odstavce + jednoduché **tučné**
const mdInline = (s) => s.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
const howItWorksParas = d.howItWorks ? d.howItWorks.split(/\n\n+/).map(mdInline) : [];

// Breadcrumb: pod-stránka odkazuje zpět na svého rodiče
let parentInfo = null;
if (d.parent) {
  const par = (await getCollection('projects')).find((p) => p.id === d.parent);
  if (par) parentInfo = { id: par.id, title: par.data.title };
}

// Interaktivní demo (Fáze 2.5)
const demoLabelsSection = {
  hra: 'Zahraj si',
  chat: 'Ukázka konverzace',
  produkt: 'Produkt v e-shopu',
  ig: 'Záznamy na Instagramu',
};
---

<BaseLayout
  title={`${project.data.title} — Tým Trampolín`}
  description={project.data.tagline}
  ogImage={`${base}${project.data.thumb}`}
>
  <Navigation active="projekty" />

  <!-- ═══ HERO ═══ -->
  <section class="relative z-10 pt-32 px-5 md:px-10">
    <div class="max-w-[80rem] mx-auto">
      <a
        href={parentInfo ? `${base}projekty/${parentInfo.id}/` : `${base}projekty/`}
        class="link-button mb-8 inline-flex"
      >
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="transform: rotate(180deg);"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        {parentInfo ? parentInfo.title : 'Všechny projekty'}
      </a>
      <div class="flex flex-wrap items-center gap-2 mb-5">
        {project.data.tags.map((tag) => (
          <span class="label !text-[0.62rem] px-2 py-0.5 border border-[var(--color-line)] text-[var(--color-text-muted)]">{tag}</span>
        ))}
        <span class="label text-[var(--color-text-muted)] ml-2">{project.data.year}</span>
      </div>
      <h1 class="display-lg text-white mb-4" transition:name={`project-title-${project.id}`}>{project.data.title}</h1>
      <p class="text-lg md:text-xl text-[var(--color-text-secondary)] max-w-2xl mb-10" style={`color: ${project.data.accent};`}>{project.data.tagline}</p>
    </div>
  </section>

  <!-- ═══ HERO MEDIA ═══ -->
  <section class="relative z-10 px-5 md:px-10 mb-16">
    <div class="max-w-[80rem] mx-auto media-frame">
      <img
        src={`${base}${project.data.thumb}`}
        alt={project.data.title}
        loading="eager"
        fetchpriority="high"
        class="w-full max-h-[36rem] object-cover"
        transition:name={`project-image-${project.id}`}
      />
    </div>
  </section>

  <!-- ═══ DEMO (Fáze 2.5) ═══ -->
  {d.demo && (
    <section class="relative z-10 px-5 md:px-10 pt-4 pb-8">
      <div class="max-w-[80rem] mx-auto">
        <p class="eyebrow mb-6">{demoLabelsSection[d.demo] ?? 'Demo'}</p>
        {d.demo === 'hra' && d.demoSrc && (
          <GameEmbed src={d.demoSrc} title={project.data.title} poster={d.demoPoster} accent={d.accent} />
        )}
        {d.demo === 'chat' && d.chatLines.length > 0 && (
          <ChatDemo lines={d.chatLines} title={project.data.title} accent={d.accent} />
        )}
        {d.demo === 'produkt' && d.product && (
          <ProductDemo
            name={project.data.title}
            price={d.product.price}
            note={d.product.note}
            cta={d.product.cta}
            image={d.thumb}
            accent={d.accent}
          />
        )}
        {d.demo === 'ig' && <IgEmbed posts={d.igPosts} accent={d.accent} />}
      </div>
    </section>
  )}

  <!-- ═══ CONTENT ═══ -->
  <section class="relative z-10 px-5 md:px-10 pb-8">
    <div class="max-w-[80rem] mx-auto grid grid-cols-1 lg:grid-cols-[2fr_1fr] gap-12">
      <div
        class="prose-dark text-[var(--color-text-secondary)] leading-relaxed max-w-2xl [&_strong]:text-white [&_p]:mb-5"
        data-track-view="project_detail_view"
        data-track-meta={JSON.stringify({ project: project.id })}
      >
        <Content />
        {linkHref && ctaLabel && (
          <a
            href={linkHref}
            class="btn-primary mt-4"
            target={ctaExternal ? '_blank' : undefined}
            rel={ctaExternal ? 'noopener noreferrer' : undefined}
            data-track={isGameLink ? 'external_game_click' : 'partner_cta_click'}
            data-track-meta={JSON.stringify({ project: project.id })}
          >
            {ctaLabel}
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        )}
      </div>
      <aside class="border-t lg:border-t-0 lg:border-l border-[var(--color-line)] pt-8 lg:pt-0 lg:pl-10 h-fit">
        <dl class="space-y-6">
          <div>
            <dt class="label text-[var(--color-text-muted)] mb-1">Rok</dt>
            <dd class="text-white font-[var(--font-mono)]">{project.data.year}</dd>
          </div>
          <div>
            <dt class="label text-[var(--color-text-muted)] mb-1">Kategorie</dt>
            <dd class="text-white">{project.data.tags.join(', ')}</dd>
          </div>
          <div>
            <dt class="label text-[var(--color-text-muted)] mb-1">Autor</dt>
            <dd class="text-white">Tým Trampolín</dd>
          </div>
        </dl>
      </aside>
    </div>
  </section>

  <!-- ═══ SUB-POLOŽKY ═══ -->
  {hasPolozky && (
    <section class="relative z-10 rule py-16 px-5 md:px-10">
      <div class="max-w-[80rem] mx-auto">
        <p class="eyebrow mb-8">Co obsahuje — {polozky.length} {polozky.length === 1 ? 'projekt' : polozky.length < 5 ? 'projekty' : 'projektů'}</p>

        {flagshipItems.length > 0 && (
          <div class:list={['grid grid-cols-1 gap-5 mb-5', flagshipItems.length > 1 && 'md:grid-cols-2']}>
            {flagshipItems.map((item) => (
              <PolozkaCard item={item} accent={d.accent} big={true} demoLabel={item.demo ? demoLabels[item.demo] : null} />
            ))}
          </div>
        )}

        {restItems.length > 0 && (
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
            {restItems.map((item) => (
              <PolozkaCard item={item} accent={d.accent} big={false} demoLabel={item.demo ? demoLabels[item.demo] : null} />
            ))}
          </div>
        )}

        {techStack.length > 0 && (
          <div class="flex flex-wrap items-center gap-2 mt-10 pt-8 border-t border-[var(--color-line)]">
            <span class="label text-[var(--color-text-muted)] mr-2">Tech stack</span>
            {techStack.map((s) => (
              <span class="label !text-[0.62rem] px-2 py-0.5 border border-[var(--color-line)] text-[var(--color-text-secondary)]">{s}</span>
            ))}
          </div>
        )}
      </div>
    </section>
  )}

  <!-- ═══ JAK TO FUNGUJE ═══ -->
  {howItWorksParas.length > 0 && (
    <section class="relative z-10 rule py-16 px-5 md:px-10">
      <div class="max-w-[80rem] mx-auto">
        <p class="eyebrow mb-8">Jak to funguje</p>
        <div class="prose-dark text-[var(--color-text-secondary)] leading-relaxed max-w-3xl [&_strong]:text-white">
          {howItWorksParas.map((p) => <p class="mb-5" set:html={p} />)}
        </div>
      </div>
    </section>
  )}

  <!-- ═══ CASE STUDY ═══ -->
  {hasCaseStudy && (
    <section class="relative z-10 rule py-16 px-5 md:px-10">
      <div class="max-w-[80rem] mx-auto">
        <p class="eyebrow mb-8">Case study</p>
        <CaseStudyBlock
          challenge={d.challenge}
          solution={d.solution}
          role={d.role}
          teamMembers={d.teamMembers}
          outcomeMetrics={d.outcomeMetrics}
          proofLinks={proofLinksResolved}
          awards={d.awards}
          sponsorFit={d.sponsorFit}
          updatedAt={d.updatedAt}
        />
      </div>
    </section>
  )}

  <!-- ═══ GALLERY ═══ -->
  {project.data.media.length > 0 && (
    <section class="relative z-10 rule py-16 px-5 md:px-10">
      <div class="max-w-[80rem] mx-auto">
        <p class="eyebrow mb-8">Galerie projektu</p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          {project.data.media.map((m) => (
            m.type === 'image' ? (
              <div class="reveal media-frame">
                <img src={`${base}${m.src}`} alt={m.alt} loading="lazy" class="w-full h-72 md:h-96 object-cover" />
              </div>
            ) : (
              <div class="reveal media-frame">
                <video controls preload="none" poster={m.poster ? `${base}${m.poster}` : undefined} class="w-full h-72 md:h-96 object-cover bg-black">
                  <source src={`${base}${m.src}`} type="video/mp4" />
                </video>
              </div>
            )
          ))}
        </div>
      </div>
    </section>
  )}

  <PageNav cards={[
    {
      href: `${base}projekty/${prev.id}/`,
      label: 'Předchozí projekt',
      title: prev.data.title,
      desc: prev.data.tagline,
    },
    {
      href: `${base}projekty/${next.id}/`,
      label: 'Další projekt',
      title: next.data.title,
      desc: next.data.tagline,
    }
  ]} />

  <Footer />
</BaseLayout>
