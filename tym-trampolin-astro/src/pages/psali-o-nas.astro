---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import SectionHeading from '../components/SectionHeading.astro';
import PageNav from '../components/PageNav.astro';

const base = import.meta.env.BASE_URL;

const mentions = [
  {
    source: 'DemocraTICon',
    type: 'Oficiální web',
    date: 'Duben 2026',
    title: 'Tým Trampolín mezi nejlepšími v ČR',
    description: 'Oficiální stránka soutěže DemocraTICon zmínila náš tým jako jednoho ze 14 finalistů, kteří se utkali o titul nejlepšího týmu v ČR v oblasti demokracie a občanství.',
    link: 'https://www.democraticon.cz',
  },
  {
    source: 'Školní časopis Shake',
    type: 'Školní média — tištěné vydání',
    date: 'Březen 2026',
    title: 'Naši studenti soutěží o budoucnost demokracie',
    description: 'Časopis Gymnázia Amazon představil náš tým a naši cestu soutěží DemocraTICon. Článek popisuje naše motivace, projekty a vizi pro budoucnost.',
    link: null,
  }
];

const pressFiles = [
  { file: 'logo-trampolin.svg', label: 'Logo — světlé pozadí', size: '1 kB', type: 'SVG' },
  { file: 'logo-trampolin-dark.svg', label: 'Logo — tmavé pozadí', size: '1 kB', type: 'SVG' },
  { file: 'press-foto-1.jpg', label: 'Press foto — finále, pódium', size: '576 kB', type: 'JPG' },
  { file: 'press-foto-2.jpg', label: 'Press foto — tým', size: '467 kB', type: 'JPG' },
  { file: 'press-foto-3.jpg', label: 'Press foto — konzultace', size: '399 kB', type: 'JPG' },
  { file: 'press-foto-4.jpg', label: 'Press foto — vystoupení', size: '664 kB', type: 'JPG' },
  { file: 'press-kit.zip', label: 'Kompletní press kit', size: '2,1 MB', type: 'ZIP' },
];

const facts = [
  { label: 'Název', value: 'Tým Trampolín' },
  { label: 'Založení', value: 'Září 2025' },
  { label: 'Členové', value: 'Hugo (strategie & technologie), Dan (operace & organizace), Vojta (prezentace & komunikace)' },
  { label: 'Škola', value: 'Gymnázium Amazon, Praha' },
  { label: 'Hlavní úspěch', value: '3. místo DemocraTICon 2026 (318 týmů, 14 finalistů; pořádá Člověk v tísni & JSNS)' },
  { label: 'Zaměření', value: 'Průnik politiky, technologií a umělé inteligence' },
  { label: 'Projekty', value: '2 hry s vlastním enginem, digitální album (10 skladeb), e-shop, fyzické artefakty, mikrokurz, analytický systém' },
  { label: 'Kontakt pro média', value: 'hugo.kubicek@icloud.com, +420 731 544 015' },
];
---

<BaseLayout title="Psali o nás — Tým Trampolín" description="Mediální zmínky o Týmu Trampolín, press kit ke stažení a fakta pro média.">
  <Navigation active="psali-o-nas" />

  <!-- ═══ HERO ═══ -->
  <section class="relative z-10 pt-36 pb-16 px-5 md:px-10">
    <div class="max-w-[80rem] mx-auto">
      <p class="reveal eyebrow mb-4">Média</p>
      <h1 class="display-lg text-white mb-8" data-split>
        Psali o nás
      </h1>
      <p class="reveal reveal-delay-1 text-lg text-[var(--color-text-secondary)] max-w-2xl leading-relaxed">
        Mediální ohlasy, press kit ke stažení a všechna fakta, která pro článek o nás potřebujete.
      </p>
    </div>
  </section>

  <!-- ═══ MENTIONS ═══ -->
  <section class="relative z-10 rule">
    <div class="max-w-[80rem] mx-auto">
      {mentions.map((mention, i) => {
        const inner = (
          <>
            <div class="flex flex-wrap items-center gap-3 mb-3">
              <span class="eyebrow">{mention.source}</span>
              <span class="label !text-[0.62rem] text-[var(--color-text-muted)]">{mention.type}</span>
              <span class="label !text-[0.62rem] text-[var(--color-text-muted)]">{mention.date}</span>
            </div>
            <h3 class="display-sm text-white mb-3">{mention.title}</h3>
            <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed max-w-2xl">{mention.description}</p>
          </>
        );
        return mention.link ? (
          <a href={mention.link} target="_blank" rel="noopener noreferrer" class:list={['group block px-5 md:px-10 py-10 no-underline hover:bg-[var(--color-ink-2)] transition-colors', i > 0 && 'border-t border-[var(--color-line)]']}>
            {inner}
            <span class="link-button mt-5">
              Přečíst článek
              <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </span>
          </a>
        ) : (
          <div class:list={['px-5 md:px-10 py-10', i > 0 && 'border-t border-[var(--color-line)]']}>
            {inner}
            <span class="label text-[var(--color-text-muted)] mt-5 inline-block">Článek vyšel v tištěném vydání</span>
          </div>
        );
      })}
    </div>
  </section>

  <!-- ═══ PRESS KIT ═══ -->
  <section class="relative z-10 rule py-24">
    <div class="max-w-[80rem] mx-auto px-5 md:px-10">
      <SectionHeading
        index="01"
        label="Press kit"
        title="Ke stažení"
        description="Loga a fotky ve vysokém rozlišení, volně k použití při psaní o našem týmu."
        center={false}
      />
    </div>
    <div class="rule">
      <div class="max-w-[80rem] mx-auto">
        {pressFiles.map((f, i) => (
          <a
            href={`${base}press/${f.file}`}
            download
            class:list={['group grid grid-cols-[3.5rem_1fr_auto] items-center gap-4 md:gap-8 px-5 md:px-10 py-5 no-underline hover:bg-[var(--color-ink-2)] transition-colors', i > 0 && 'border-t border-[var(--color-line)]']}
          >
            <span class="label !text-[0.62rem] border border-[var(--color-line-strong)] text-[var(--color-brand)] py-1.5 text-center">{f.type}</span>
            <span>
              <span class="text-white font-medium group-hover:text-[var(--color-brand-hot)] transition-colors block">{f.label}</span>
              <span class="label !text-[0.62rem] text-[var(--color-text-muted)]">{f.file} &bull; {f.size}</span>
            </span>
            <svg class="text-[var(--color-text-muted)] group-hover:text-[var(--color-brand)] group-hover:translate-y-1 transition-all" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ FAKTA PRO MÉDIA — paper cut ═══ -->
  <section class="relative z-10 rule-strong on-paper py-24">
    <div class="max-w-[80rem] mx-auto px-5 md:px-10">
      <p class="eyebrow mb-4">Fakta pro média</p>
      <h2 class="display-md mb-10">Vše podstatné na jednom místě</h2>
      <dl class="border-2 border-[var(--color-ink-text)]/15 divide-y-2 divide-[var(--color-ink-text)]/10 bg-white/40">
        {facts.map((fact) => (
          <div class="grid grid-cols-1 md:grid-cols-[12rem_1fr] gap-1 md:gap-8 px-5 md:px-8 py-4">
            <dt class="label !text-[0.68rem] opacity-60 pt-0.5">{fact.label}</dt>
            <dd class="text-[0.95rem] leading-relaxed">{fact.value}</dd>
          </div>
        ))}
      </dl>
      <p class="text-sm opacity-70 mt-6">Text je volně k převzetí. Pro rozhovory a doplňující informace nás kontaktujte.</p>
    </div>
  </section>

  <!-- ═══ CTA ═══ -->
  <section class="relative z-10 rule py-20 px-5 md:px-10">
    <div class="max-w-[80rem] mx-auto flex flex-col md:flex-row md:items-center justify-between gap-8">
      <div>
        <h2 class="display-md text-white mb-3">Chcete o nás napsat?</h2>
        <p class="text-[var(--color-text-secondary)] max-w-lg">
          Jsme otevřeni rozhovorům, článkům i mediální spolupráci. Rádi poskytneme veškeré informace.
        </p>
      </div>
      <a href={`${base}kontakt/`} class="btn-primary shrink-0">
        Kontaktovat nás
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </section>

  <PageNav cards={[
    {
      href: `${base}projekty/`,
      label: 'Portfolio',
      title: 'Naše projekty',
      desc: 'Hry, hudba, e-shop a fyzické artefakty',
    },
    {
      href: `${base}kontakt/`,
      label: 'Kontakt',
      title: 'Napište nám',
      desc: 'Email, telefon nebo sociální sítě',
    }
  ]} />

  <Footer />
</BaseLayout>
