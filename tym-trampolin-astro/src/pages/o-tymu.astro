---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import SectionHeading from '../components/SectionHeading.astro';
import PageNav from '../components/PageNav.astro';

const base = import.meta.env.BASE_URL;

const members = [
  {
    name: 'Hugo',
    role: 'Strategie & technologie',
    photo: `${base}media/team-coding.webp`,
    pos: 'center 30%',
    bio: 'Vedoucí týmu a hlavní architekt všech technických projektů. Navrhl a naprogramoval celý web, obě hry, e-shop, hudební přehrávač i analytický systém. Zodpovídá za celkovou strategii a směřování týmu.',
    skills: ['JavaScript', 'Python', 'Web Development', 'Game Dev', 'AI/ML', 'Analytika'],
    quote: 'Každý řádek kódu je příležitost něco změnit.'
  },
  {
    name: 'Dan',
    role: 'Operace & organizace',
    photo: `${base}media/team-consultation.webp`,
    pos: 'center 35%',
    bio: 'Organizační mozek týmu. Koordinuje harmonogramy, logistiku a komunikaci. Díky němu jsou projekty dodávány včas. Specialista na projektové řízení a provozní efektivitu.',
    skills: ['Projektové řízení', 'Logistika', 'Komunikace', 'Plánování', 'Analýza'],
    quote: 'Dobrá organizace je základem každého úspěchu.'
  },
  {
    name: 'Vojta',
    role: 'Prezentace & komunikace',
    photo: `${base}media/finale-stage-1.webp`,
    pos: 'center 25%',
    bio: 'Hlas a tvář týmu. Zodpovídá za veřejná vystoupení, prezentace před porotou a komunikační strategii. Umí složitá témata vysvětlit srozumitelně a přesvědčivě.',
    skills: ['Public speaking', 'Prezentace', 'Copywriting', 'Komunikace', 'Storytelling'],
    quote: 'Nejlepší myšlenka nemá cenu, pokud ji nedokážete sdělit.'
  }
];

const timeline = [
  { date: 'Září 2025', title: 'Založení týmu', description: 'Tři studenti Gymnázia Amazon se rozhodli společně soutěžit v DemocraTICon.' },
  { date: 'Říjen 2025', title: '1. kolo soutěže', description: 'Základní registrace a první úlohy. Začali jsme budovat svou strategii.' },
  { date: 'Leden 2026', title: 'Vývoj webu a projektů', description: 'Spustili jsme web, hry, e-shop a digitální album. Vše od nuly.' },
  { date: 'Březen 2026', title: 'Postup do finále', description: 'Z 318 týmů jsme se probojovali mezi 14 nejlepších v ČR.' },
  { date: 'Duben 2026', title: '3. místo v ČR', description: 'Finále DemocraTICon 2026 v Praze. Bronzová medaile a úžasná zkušenost.' },
  { date: 'Nyní', title: 'Nový začátek', description: 'Hledáme partnery a rozšiřujeme naše aktivity za hranice soutěže.' },
];

const values = [
  { title: 'Inovace', desc: 'Nehledáme snadná řešení. Každý projekt je příležitost naučit se něco nového a posunout hranice.' },
  { title: 'AI-first přístup', desc: 'Umělá inteligence není jen buzzword. Je to nástroj, který aktivně používáme a zkoumáme.' },
  { title: 'Spolupráce', desc: 'Věříme, že nejlepší výsledky vznikají, když různé pohledy spolupracují na společném cíli.' },
  { title: 'Vzdělávání', desc: 'Sdílíme, co se naučíme. Prostřednictvím open-source kódu, mikrokurzů a veřejných prezentací.' }
];
---

<BaseLayout title="O týmu — Tým Trampolín" description="Poznejte náš tým. Tři studenti Gymnázia Amazon v Praze na průniku politiky, technologií a AI.">
  <Navigation active="o-tymu" />

  <!-- ═══ HERO ═══ -->
  <section class="relative overflow-hidden bg-[var(--color-ink)]">
    <div class="relative pt-36 pb-20 px-5 md:px-10 z-10">
      <div class="max-w-[80rem] mx-auto">
        <p class="reveal eyebrow mb-4">Gymnázium Amazon, Praha</p>
        <h1 class="display-lg text-white mb-8" data-split>
          Poznejte<br/>náš tým
        </h1>
        <p class="reveal reveal-delay-1 text-lg text-[var(--color-text-secondary)] max-w-2xl leading-relaxed">
          Jsme tři studenti, kteří věří, že technologie a politika mohou jít ruku v ruce. Každý z nás přináší jedinečný pohled i dovednosti.
        </p>
      </div>
    </div>
    <div class="relative media-frame !border-x-0 !rounded-none cut-diagonal">
      <img src={`${base}media/team-consultation.webp`} alt="Tým Trampolín při práci" loading="eager" fetchpriority="high" class="w-full h-[40vh] md:h-[55vh] object-cover scroll-parallax" style="object-position: center 35%;" />
    </div>
  </section>

  <!-- ═══ TEAM MEMBERS ═══ -->
  <section class="relative z-10 py-24">
    <div class="max-w-[80rem] mx-auto px-5 md:px-10">
      <SectionHeading index="01" label="Členové" title="Tři role, jeden tým" center={false} />
    </div>
    <div class="rule">
      <div class="max-w-[80rem] mx-auto grid grid-cols-1 lg:grid-cols-3">
        {members.map((member, i) => (
          <div class:list={['reveal group border-[var(--color-line)] hover:bg-[var(--color-ink-2)] transition-colors', i > 0 && 'border-t lg:border-t-0 lg:border-l', i > 0 && `reveal-delay-${i}`]}>
            <div class="overflow-hidden h-56">
              <img src={member.photo} alt={`${member.name} — ${member.role}`} loading="lazy" class="w-full h-full object-cover group-hover:scale-[1.04] transition-transform duration-500" style={`object-position: ${member.pos}; filter: saturate(0.9);`} />
            </div>
            <div class="p-8 md:p-10 !pt-8">
            <h3 class="display-sm text-white mb-1">{member.name}</h3>
            <p class="label text-[var(--color-brand)] mb-5">{member.role}</p>
            <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed mb-6">{member.bio}</p>
            <blockquote class="text-sm text-[var(--color-text-muted)] italic border-l-2 border-[var(--color-brand)] pl-4 mb-6">
              &bdquo;{member.quote}&ldquo;
            </blockquote>
            <div class="flex flex-wrap gap-2">
              {member.skills.map((skill) => (
                <span class="label !text-[0.62rem] px-2.5 py-1 text-[var(--color-text-muted)] border border-[var(--color-line)]">
                  {skill}
                </span>
              ))}
            </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ VALUES ═══ -->
  <section class="relative z-10 rule py-24">
    <div class="max-w-[80rem] mx-auto px-5 md:px-10">
      <SectionHeading
        index="02"
        label="Hodnoty"
        title="Čemu věříme"
        description="Naše práce stojí na čtyřech pilířích, které nás definují."
        center={false}
      />
    </div>
    <div class="rule">
      <div class="max-w-[80rem] mx-auto grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4">
        {values.map((v, i) => (
          <div class:list={['reveal group p-8 border-[var(--color-line)] hover:bg-[var(--color-ink-2)] transition-colors', i > 0 && 'border-t sm:border-t-0 max-sm:border-t', i % 2 === 1 && 'sm:border-l', i >= 2 && 'sm:border-t lg:border-t-0', i > 0 && 'lg:border-l', i > 0 && `reveal-delay-${Math.min(i, 3)}`]}>
            <div class="label text-[var(--color-text-muted)] mb-5">0{i + 1}</div>
            <h4 class="display-sm !text-lg text-white mb-3 group-hover:text-[var(--color-brand-hot)] transition-colors">{v.title}</h4>
            <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">{v.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ TIMELINE ═══ -->
  <section class="relative z-10 rule py-24 px-5 md:px-10">
    <div class="max-w-[80rem] mx-auto">
      <SectionHeading index="03" label="Náš příběh" title="Od nuly k bronzu" center={false} />

      <div class="mt-4 max-w-3xl">
        {timeline.map((item, i) => (
          <div class:list={['reveal group grid grid-cols-[6rem_1fr] md:grid-cols-[10rem_1fr] gap-6 py-6', i > 0 && 'border-t border-[var(--color-line)]']}>
            <div class="label text-[var(--color-brand)] pt-1">{item.date}</div>
            <div>
              <h4 class="display-sm !text-xl text-white mb-1 group-hover:text-[var(--color-brand-hot)] transition-colors">{item.title}</h4>
              <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">{item.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <PageNav cards={[
    {
      href: `${base}projekty/`,
      label: 'Portfolio',
      title: 'Projekty',
      desc: 'Hry, hudba, artefakty — vše od nuly',
    },
    {
      href: `${base}podpora/`,
      label: 'Partnerství',
      title: 'Podpořte nás',
      desc: 'Finanční i mediální spolupráce',
    }
  ]} />

  <Footer />
</BaseLayout>
