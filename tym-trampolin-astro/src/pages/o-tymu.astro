---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import SectionHeading from '../components/SectionHeading.astro';
import PageNav from '../components/PageNav.astro';

const base = import.meta.env.BASE_URL;

const members = [
  {
    name: 'Hugo',
    role: 'Strategie & technologie',
    initial: 'H',
    bio: 'Vedoucí týmu a hlavní architekt všech technických projektů. Navrhl a naprogramoval celý web, obě hry, e-shop, hudební přehrávač i analytický systém. Zodpovídá za celkovou strategii a směřování týmu.',
    skills: ['JavaScript', 'Python', 'Web Development', 'Game Dev', 'AI/ML', 'Analytika'],
    quote: 'Každý řádek kódu je příležitost něco změnit.'
  },
  {
    name: 'Dan',
    role: 'Operace & organizace',
    initial: 'D',
    bio: 'Organizační mozek týmu. Koordinuje harmonogramy, logistiku a komunikaci. Díky němu jsou projekty dodávány včas. Specialista na projektové řízení a provozní efektivitu.',
    skills: ['Projektové řízení', 'Logistika', 'Komunikace', 'Plánování', 'Analýza'],
    quote: 'Dobrá organizace je základem každého úspěchu.'
  },
  {
    name: 'Vojta',
    role: 'Prezentace & komunikace',
    initial: 'V',
    bio: 'Hlas a tvář týmu. Zodpovídá za veřejná vystoupení, prezentace před porotou a komunikační strategii. Umí složitá témata vysvětlit srozumitelně a přesvědčivě.',
    skills: ['Public speaking', 'Prezentace', 'Copywriting', 'Komunikace', 'Storytelling'],
    quote: 'Nejlepší myšlenka nemá cenu, pokud ji nedokážete sdělit.'
  }
];

const timeline = [
  { date: 'Září 2025', title: 'Založení týmu', description: 'Tři studenti Gymnázia Amazon se rozhodli společně soutěžit v DemocraTICon.' },
  { date: 'Říjen 2025', title: '1. kolo soutěže', description: 'Základní registrace a první úlohy. Začali jsme budovat svou strategii.' },
  { date: 'Leden 2026', title: 'Vývoj webu a projektů', description: 'Spustili jsme web, hry, e-shop a digitální album. Vše od nuly.' },
  { date: 'Březen 2026', title: 'Postup do finále', description: 'Z 318 týmů jsme se probojovali mezi 14 nejlepších v ČR.' },
  { date: 'Duben 2026', title: '3. místo v ČR', description: 'Finále DemocraTICon 2026 v Praze. Bronzová medaile a úžasná zkušenost.' },
  { date: 'Nyní', title: 'Nový začátek', description: 'Hledáme partnery a rozšiřujeme naše aktivity za hranice soutěže.' },
];

const values = [
  {
    icon: '<svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/></svg>',
    title: 'Inovace',
    desc: 'Nehledáme snadná řešení. Každý projekt je příležitost naučit se něco nového a posunout hranice.'
  },
  {
    icon: '<svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/></svg>',
    title: 'AI-first přístup',
    desc: 'Umělá inteligence není jen buzzword. Je to nástroj, který aktivně používáme a zkoumáme.'
  },
  {
    icon: '<svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z"/></svg>',
    title: 'Spolupráce',
    desc: 'Věříme, že nejlepší výsledky vznikají, když různé pohledy spolupracují na společném cíli.'
  },
  {
    icon: '<svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342"/></svg>',
    title: 'Vzdělávání',
    desc: 'Sdílíme, co se naučíme. Prostřednictvím open-source kódu, mikrokurzů a veřejných prezentací.'
  }
];
---

<BaseLayout title="O týmu — Tým Trampolín" description="Poznejte náš tým. Tři studenti Gymnázia Amazon v Praze na průniku politiky, technologií a AI.">
  <Navigation active="o-tymu" />

  <!-- ═══ HERO ═══ -->
  <section class="relative z-10 pt-32 pb-16 px-6 min-h-[500px] overflow-hidden" style={`background: linear-gradient(rgba(8, 18, 40, 0.70), rgba(8, 18, 40, 0.70)), url('${base}media/IMG_7783.jpg'); background-size: cover; background-position: center; background-attachment: fixed; filter: brightness(0.8) saturate(0.6) contrast(1.1);`}>
    <div class="max-w-4xl mx-auto text-center">
      <div class="reveal inline-flex items-center gap-2 px-4 py-2 rounded-full glass mb-6">
        <span class="text-xs font-medium text-[var(--color-text-secondary)]">Gymnázium Amazon, Praha</span>
      </div>
      <h1 class="reveal text-4xl md:text-6xl font-bold tracking-tight mb-6">
        Poznejte náš <span class="text-gradient">tým</span>
      </h1>
      <p class="reveal reveal-delay-1 text-lg text-[var(--color-text-secondary)] max-w-2xl mx-auto leading-relaxed">
        Jsme tři studenti, kteří věří, že technologie a politika mohou jít ruku v ruce. Každý z nás přináší jedinečný pohled i dovednosti.
      </p>
    </div>
  </section>

  <!-- ═══ TEAM MEMBERS ═══ -->
  <section class="relative z-10 py-16 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        {members.map((member, i) => (
          <div class={`reveal ${i > 0 ? `reveal-delay-${i}` : ''} tilt-3d glass-strong p-8 rounded-2xl group hover:border-[var(--color-accent)]/20 transition-colors duration-300 relative`}>
            <!-- Avatar -->
            <div class="w-20 h-20 rounded-2xl bg-gradient-to-br from-[var(--color-accent)] to-[var(--color-accent-2)] flex items-center justify-center mb-6 group-hover:scale-105 transition-transform shadow-lg shadow-[var(--color-accent-glow)]">
              <span class="text-3xl font-bold text-white font-[var(--font-heading)]">{member.initial}</span>
            </div>

            <!-- Info -->
            <h3 class="text-2xl font-bold text-white mb-1">{member.name}</h3>
            <p class="text-sm text-[var(--color-accent)] font-semibold uppercase tracking-wider mb-4">{member.role}</p>
            <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed mb-6">{member.bio}</p>

            <!-- Quote -->
            <blockquote class="text-sm text-[var(--color-text-muted)] italic border-l-2 border-[var(--color-accent)]/30 pl-4 mb-6">
              &bdquo;{member.quote}&ldquo;
            </blockquote>

            <!-- Skills -->
            <div class="flex flex-wrap gap-2">
              {member.skills.map((skill) => (
                <span class="px-2.5 py-1 text-[0.65rem] font-medium rounded-lg bg-white/5 text-[var(--color-text-muted)] border border-[var(--color-line)]">
                  {skill}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ VALUES ═══ -->
  <section class="relative z-10 py-24 px-6">
    <div class="max-w-6xl mx-auto">
      <SectionHeading
        label="Hodnoty"
        title='Čemu <span class="text-gradient">věříme</span>'
        description="Naše práce stojí na čtyřech pilířích, které nás definují."
      />

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mt-12">
        {values.map((v, i) => (
          <div class={`reveal ${i > 0 ? `reveal-delay-${i}` : ''} tilt-3d glass p-6 rounded-2xl text-center hover:border-[var(--color-accent)]/20 transition-colors duration-300 relative`}>
            <div class="w-12 h-12 mx-auto rounded-xl bg-[var(--color-accent)]/10 flex items-center justify-center mb-4 text-[var(--color-accent-bright)]" set:html={v.icon} />
            <h4 class="text-base font-bold text-white mb-2">{v.title}</h4>
            <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">{v.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ TIMELINE ═══ -->
  <section class="relative z-10 py-24 px-6">
    <div class="max-w-3xl mx-auto">
      <SectionHeading
        label="Náš příběh"
        title='Cesta od <span class="text-gradient">nuly k bronzu</span>'
      />

      <div class="mt-12 relative">
        <!-- Vertical line -->
        <div class="absolute left-5 md:left-1/2 top-0 bottom-0 w-px bg-[var(--color-line)] md:-translate-x-px" aria-hidden="true"></div>

        {timeline.map((item, i) => (
          <div class={`reveal ${i > 0 ? `reveal-delay-${Math.min(i, 3)}` : ''} relative flex items-start gap-6 mb-10 md:even:flex-row-reverse md:even:text-right group`}>
            <!-- Dot -->
            <div class="absolute left-5 md:left-1/2 w-3 h-3 rounded-full bg-[var(--color-accent)] border-2 border-[var(--color-bg-deep)] -translate-x-1/2 mt-1.5 group-hover:scale-150 transition-transform z-10" />

            <!-- Content -->
            <div class="ml-12 md:ml-0 md:w-[calc(50%-2rem)]">
              <span class="text-xs font-semibold text-[var(--color-accent)] uppercase tracking-wider">{item.date}</span>
              <h4 class="text-base font-bold text-white mt-1 mb-1">{item.title}</h4>
              <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">{item.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <PageNav cards={[
    {
      href: `${base}uspechy/`,
      label: 'Projekty & soutěže',
      title: 'Naše úspěchy',
      desc: '3. místo z 318 týmů, hry, hudba a více',
      icon: '<svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M16.5 18.75h-9m9 0a3 3 0 013 3h-15a3 3 0 013-3m9 0v-3.375c0-.621-.503-1.125-1.125-1.125h-.871M7.5 18.75v-3.375c0-.621.504-1.125 1.125-1.125h.872m5.007 0H9.497m5.007 0a7.454 7.454 0 01-.982-3.172M9.497 14.25a7.454 7.454 0 00.981-3.172M5.25 4.236c-.982.143-1.954.317-2.916.52A6.003 6.003 0 007.73 9.728M5.25 4.236V4.5c0 2.108.966 3.99 2.48 5.228M5.25 4.236V2.721C7.456 2.41 9.71 2.25 12 2.25c2.291 0 4.545.16 6.75.47v1.516M7.73 9.728a6.726 6.726 0 002.748 1.35m8.272-6.842V4.5c0 2.108-.966 3.99-2.48 5.228m2.48-5.492a46.32 46.32 0 012.916.52 6.003 6.003 0 01-5.395 4.972m0 0a6.726 6.726 0 01-2.749 1.35m0 0a6.772 6.772 0 01-3.044 0"/></svg>'
    },
    {
      href: `${base}podpora/`,
      label: 'Partnerství',
      title: 'Podpořte nás',
      desc: 'Finanční i mediální spolupráce',
      icon: '<svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"/></svg>'
    }
  ]} />

  <Footer />
</BaseLayout>
