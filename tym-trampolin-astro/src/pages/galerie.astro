---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import PageNav from '../components/PageNav.astro';

const base = import.meta.env.BASE_URL;

const images = Object.values(
  import.meta.glob<{ default: ImageMetadata }>('../assets/images/gallery/*.jpg', { eager: true })
).map((m) => m.default);
---

<BaseLayout
  title="Galerie — Tým Trampolín"
  description="Fotografie z finále DemocraTICon 2026, workshopů a života týmu."
>
  <Navigation active="galerie" />

  <!-- ═══ HERO ═══ -->
  <section class="relative z-10 pt-36 pb-16 px-5 md:px-10">
    <div class="max-w-[80rem] mx-auto">
      <p class="reveal eyebrow mb-4">{images.length} fotek</p>
      <h1 class="display-lg text-white mb-8" data-split>
        Galerie
      </h1>
      <p class="reveal reveal-delay-1 text-lg text-[var(--color-text-secondary)] max-w-2xl leading-relaxed">
        Finále DemocraTICon 2026 v Praze, workshopy a zákulisí týmu. Klikněte na fotku pro zvětšení.
      </p>
    </div>
  </section>

  <!-- ═══ GRID ═══ -->
  <section class="relative z-10 rule py-12 px-5 md:px-10">
    <div class="max-w-[80rem] mx-auto columns-1 sm:columns-2 lg:columns-3 gap-5 [&>*]:mb-5">
      {images.map((img, i) => (
        <button
          type="button"
          class="gallery-item reveal media-frame block w-full cursor-zoom-in group p-0 border-0 text-left"
          data-index={i}
          aria-label={`Zvětšit fotku ${i + 1} z ${images.length}`}
        >
          <Image
            src={img}
            alt={`Tým Trampolín — fotka ${i + 1}: finále DemocraTICon 2026 a život týmu`}
            widths={[420, 800, 1400]}
            sizes="(max-width: 640px) 92vw, (max-width: 1024px) 46vw, 30vw"
            format="webp"
            quality={78}
            class="w-full h-auto group-hover:scale-[1.02] group-hover:opacity-90 transition-all duration-500"
            loading={i < 3 ? 'eager' : 'lazy'}
          />
        </button>
      ))}
    </div>
  </section>

  <!-- ═══ LIGHTBOX ═══ -->
  <dialog id="lightbox" class="backdrop:bg-[var(--color-ink)]/95 bg-transparent max-w-none max-h-none w-full h-full m-0 p-0">
    <div class="w-full h-full flex flex-col items-center justify-center p-4 md:p-10" id="lightbox-surface">
      <img id="lightbox-img" src="" alt="" class="max-w-full max-h-[82vh] object-contain border border-[var(--color-line-strong)]" />
      <div class="flex items-center gap-6 mt-5">
        <button id="lb-prev" class="btn-outline !px-4 !py-2" aria-label="Předchozí fotka">←</button>
        <span id="lb-counter" class="label text-[var(--color-text-secondary)]">01 / {String(images.length).padStart(2, '0')}</span>
        <button id="lb-next" class="btn-outline !px-4 !py-2" aria-label="Další fotka">→</button>
        <button id="lb-close" class="btn-primary !px-4 !py-2" aria-label="Zavřít">✕</button>
      </div>
    </div>
  </dialog>

  <PageNav cards={[
    {
      href: `${base}uspechy/`,
      label: 'Soutěž',
      title: 'Naše úspěchy',
      desc: 'Příběh za těmito fotkami',
    },
    {
      href: `${base}projekty/`,
      label: 'Portfolio',
      title: 'Projekty',
      desc: 'Hry, hudba a fyzické artefakty',
    }
  ]} />

  <Footer />

  <script>
    import '../scripts/lightbox.ts';
  </script>
</BaseLayout>
