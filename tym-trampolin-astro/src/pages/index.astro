---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ProofStrip from '../components/trust/ProofStrip.astro';
import SponsorCTA from '../components/trust/SponsorCTA.astro';

const base = import.meta.env.BASE_URL;

const marqueeItems = [
  'Novinka: DOOM Bounce 2.0',
  '3. místo DemocraTICon 2026',
  '318 týmů',
  '14 finalistů',
  'Politika × Technologie × AI',
  'Vše od nuly, bez šablon',
];

const showcase = [
  {
    eyebrow: 'Soutěž — 3. místo v ČR',
    title: 'DemocraTICon 2026',
    desc: 'Národní soutěž o demokracii. 318 týmů, 3 kola, 14 finalistů. Téma: mezinárodní právo a pluralita. Bronz pro nás.',
    href: `${base}uspechy/`,
    cta: 'Příběh soutěže',
    image: `${base}media/historical-costumes.webp`,
    tag: '01',
    accent: 'var(--color-gold)',
  },
  {
    eyebrow: 'Novinka — DOOM Bounce 2.0',
    title: 'Cesta na vrchol',
    desc: 'Velký update naší FPS: kampaň s 20 vlnami a 10 bossy, anime cutscény s českým dabingem, obchod, perky, online žebříčky a mobilní ovládání. Pořád jeden HTML soubor.',
    href: `${base}projekty/doom-bounce/`,
    cta: 'Prozkoumat 2.0',
    image: `${base}media/doom/doom_title.webp`,
    tag: '02',
    accent: 'var(--color-rose)',
    isNew: true,
  },
  {
    eyebrow: 'Hudba — 10 skladeb',
    title: 'Digitální album',
    desc: 'Vlastní hymna v deseti žánrových verzích — od phonku po hardstyle. Imerzivní přehrávač s vizualizací sladěnou s rytmem.',
    href: `${base}music/`,
    cta: 'Poslechnout',
    image: `${base}media/finale-stage-1.webp`,
    tag: '03',
    accent: 'var(--color-accent-2)',
  },
  {
    eyebrow: 'Fyzické artefakty',
    title: 'Klíčenka & Socha',
    desc: 'Nejen pixely. Navrhli jsme a vyrobili vlastní klíčenku a sochu — od 3D modelu po fyzický kus, který podržíte v ruce.',
    href: `${base}projekty/`,
    cta: 'Prohlédnout',
    image: `${base}media/socha-foto-1.webp`,
    tag: '04',
    accent: 'var(--color-emerald)',
  },
];

const team = [
  { name: 'Hugo', role: 'Strategie & technologie', photo: `${base}media/team-coding.webp`, pos: 'center 30%', desc: 'Vedoucí týmu, architekt webu, vývojář her a analytických systémů.' },
  { name: 'Dan', role: 'Operace & organizace', photo: `${base}media/team-consultation.webp`, pos: 'center 35%', desc: 'Organizační mozek týmu. Řídí logistiku, plánování a dodání projektů.' },
  { name: 'Vojta', role: 'Prezentace & komunikace', photo: `${base}media/finale-stage-1.webp`, pos: 'center 25%', desc: 'Hlas týmu. Specialista na prezentace a veřejná vystoupení.' },
];
---

<BaseLayout
  title="Tým Trampolín — studentský tým pro AI a demokracii"
  description="Studenti, kteří mění pravidla hry. Na průniku politiky, technologií a umělé inteligence. 3. místo DemocraTICon 2026."
>
  <Navigation active="home" />

  <!-- ═══ HERO — signature shader ═══ -->
  <section class="relative min-h-[100svh] flex items-center overflow-hidden bg-[var(--color-ink)]">
    <canvas id="hero-shader" aria-hidden="true"></canvas>
    <!-- static fallback wash for mobile / reduced motion -->
    <div class="absolute inset-0 z-0 pointer-events-none md:hidden" aria-hidden="true"
      style="background: radial-gradient(ellipse 90% 60% at 30% 80%, rgba(79,200,255,0.14), transparent 60%), radial-gradient(ellipse 60% 45% at 85% 20%, rgba(125,139,255,0.10), transparent 55%);"></div>

    <div class="relative z-10 max-w-[80rem] mx-auto px-5 md:px-10 w-full pt-28 pb-20">
      <div class="reveal flex flex-wrap items-center gap-x-6 gap-y-3 mb-8">
        <span class="inline-flex items-center gap-3">
          <span class="w-2 h-2 bg-[var(--color-gold)]" aria-hidden="true"></span>
          <span class="label text-[var(--color-text-secondary)]">3. místo — DemocraTICon 2026 — 318 týmů</span>
        </span>
        <a href={`${base}projekty/doom-bounce/`} class="inline-flex items-center gap-2.5 no-underline group/news" data-track="project_detail_view" data-track-meta='{"placement":"hero-news","project":"doom-bounce"}'>
          <span class="label !text-[0.62rem] bg-[var(--color-rose)] text-[var(--color-ink)] px-2 py-1 font-bold">Novinka</span>
          <span class="label text-[var(--color-text-secondary)] group-hover/news:text-[var(--color-rose)] transition-colors">DOOM Bounce 2.0 — Cesta na vrchol →</span>
        </a>
      </div>

      <h1 class="display-xl text-white mb-8" data-split>
        Tým<br/>Trampolín
      </h1>

      <div class="max-w-2xl">
        <p class="reveal reveal-delay-1 text-lg md:text-2xl text-[var(--color-text-secondary)] leading-relaxed mb-4">
          Studentský tým, který <span id="rotating-word" class="text-[var(--color-brand)] font-semibold">mění pravidla hry</span>.
        </p>
        <p class="reveal reveal-delay-2 text-base md:text-lg text-[var(--color-text-muted)] leading-relaxed mb-10">
          Tvoříme na průniku <strong class="text-white font-medium">politiky</strong>, <strong class="text-white font-medium">technologií</strong> a <strong class="text-white font-medium">umělé inteligence</strong> — hry, hudbu, weby i fyzické artefakty. Vše od nuly.
        </p>
      </div>

      <div class="reveal reveal-delay-3 flex flex-col sm:flex-row items-start sm:items-center gap-4">
        <a href={`${base}projekty/`} class="magnetic btn-primary text-base px-8 py-4" data-magnetic="10">
          Prozkoumat projekty
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href={`${base}partnerstvi/`} class="magnetic btn-outline text-base px-8 py-4" data-magnetic="8" data-track="partner_cta_click" data-track-meta='{"placement":"hero"}'>
          Stát se partnerem
        </a>
      </div>
    </div>

    <!-- Scroll hint -->
    <div class="absolute left-5 md:left-10 bottom-6 hidden md:flex items-center gap-3 opacity-60 z-10">
      <span class="label text-[var(--color-text-muted)]">Scroll</span>
      <span class="w-10 h-[2px] bg-[var(--color-brand)] origin-left" style="animation: scrollPulse 2s ease-in-out infinite;"></span>
    </div>
  </section>

  <!-- ═══ MARQUEE ═══ -->
  <div class="marquee-band rule-strong border-b-2 border-[var(--color-ink)]" aria-hidden="true">
    <div class="marquee-track">
      {[0, 1].map(() => (
        <div class="flex shrink-0">
          {marqueeItems.map((item) => (
            <span class="marquee-item">{item} <span class="mx-2">✳</span></span>
          ))}
        </div>
      ))}
    </div>
  </div>

  <!-- ═══ PROOF STRIP ═══ -->
  <ProofStrip limit={4} />

  <!-- ═══ CO DĚLÁME ═══ -->
  <section class="relative z-10 rule py-24">
    <div class="max-w-[80rem] mx-auto px-5 md:px-10">
      <SectionHeading
        index="01"
        label="Naše mise"
        title="Co děláme"
        description="Propojujeme svět politiky s moderními technologiemi. Ukazujeme, že studenti mohou být hybateli změn."
        center={false}
      />
    </div>
    <div class="rule">
      <div class="max-w-[80rem] mx-auto grid grid-cols-1 md:grid-cols-3">
        {[
          {
            title: 'Politika & AI',
            desc: 'Zkoumáme, jak umělá inteligence může proměnit politické procesy, vzdělávání a občanskou participaci.',
            num: 'A',
          },
          {
            title: 'Digitální tvorba',
            desc: 'Tvoříme hry, webové aplikace, hudbu a interaktivní vzdělávací obsah. Vše od nuly, bez šablon.',
            num: 'B',
          },
          {
            title: 'Vzdělávání',
            desc: 'Sdílíme znalosti prostřednictvím mikrokurzů, workshopů a otevřeného kódu. Vzdělávání má být dostupné všem.',
            num: 'C',
          },
        ].map((item, i) => (
          <div class:list={['reveal group p-8 md:p-10 border-[var(--color-line)] hover:bg-[var(--color-ink-2)] transition-colors', i > 0 && 'border-t md:border-t-0 md:border-l', i > 0 && `reveal-delay-${i}`]}>
            <div class="num-outline text-6xl mb-6 group-hover:[-webkit-text-stroke-color:var(--color-brand)] transition-all">{item.num}</div>
            <h3 class="display-sm text-white mb-4">{item.title}</h3>
            <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ PROJECTS — sticky stack showcase ═══ -->
  <section class="relative z-10 rule py-24" id="projekty-showcase">
    <div class="max-w-[80rem] mx-auto px-5 md:px-10">
      <SectionHeading
        index="02"
        label="Portfolio"
        title="Projekty"
        description="Každý projekt tvoříme od nuly. Žádné šablony, žádné zkratky — a pořád přibývají nové."
        center={false}
      />
    </div>

    <div class="max-w-[80rem] mx-auto px-5 md:px-10 flex flex-col gap-8 md:gap-0">
      {showcase.map((p, i) => (
        <div class="md:sticky stack-card" style={`top: calc(5rem + ${i} * 1.75rem); z-index: ${i + 1};`}>
          <a href={p.href} class="group grid grid-cols-1 md:grid-cols-2 no-underline bg-[var(--color-ink-2)] border border-[var(--color-line-strong)] overflow-hidden card-hover">
            <div class="relative h-56 md:h-[26rem] overflow-hidden media-frame !border-0 !rounded-none">
              <img
                src={p.image}
                alt=""
                loading={i === 0 ? 'eager' : 'lazy'}
                class="absolute inset-0 w-full h-full object-cover scroll-parallax group-hover:scale-[1.03] transition-transform duration-700"
                style="filter: saturate(0.85) contrast(1.05);"
              />
              <span class="absolute top-5 left-5 num-outline text-7xl" style={`-webkit-text-stroke-color: ${p.accent};`}>{p.tag}</span>
              {p.isNew && (
                <span class="absolute top-5 right-5 label !text-[0.68rem] bg-[var(--color-rose)] text-[var(--color-ink)] px-3 py-1.5 font-bold inline-flex items-center gap-2">
                  <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-ink)] animate-pulse" aria-hidden="true"></span>
                  Novinka
                </span>
              )}
            </div>
            <div class="p-8 md:p-12 flex flex-col justify-between gap-8">
              <div>
                <p class="eyebrow mb-4" style={`color: ${p.accent};`}>{p.eyebrow}</p>
                <h3 class="display-md text-white mb-5 group-hover:text-[var(--color-brand-hot)] transition-colors">{p.title}</h3>
                <p class="text-[var(--color-text-secondary)] leading-relaxed max-w-md">{p.desc}</p>
              </div>
              <span class="link-button">
                {p.cta}
                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </span>
            </div>
          </a>
        </div>
      ))}
    </div>

    <div class="max-w-[80rem] mx-auto px-5 md:px-10 mt-16 text-center md:text-left">
      <a href={`${base}projekty/`} class="btn-outline">
        Všechny projekty
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </section>

  <!-- ═══ TÝM ═══ -->
  <section class="relative z-10 rule py-24">
    <div class="max-w-[80rem] mx-auto px-5 md:px-10">
      <SectionHeading
        index="03"
        label="Náš tým"
        title="Tři lidé, jedna vize"
        description="Každý z nás přináší jedinečné dovednosti. Společně tvoříme něco většího."
        center={false}
      />

      <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-[var(--color-line)] border border-[var(--color-line)] mb-12">
        {team.map((member, i) => (
          <div class:list={['reveal group bg-[var(--color-ink)] hover:bg-[var(--color-ink-2)] transition-colors', i > 0 && `reveal-delay-${i}`]}>
            <div class="overflow-hidden h-52">
              <img src={member.photo} alt={`${member.name} — ${member.role}`} loading="lazy" class="w-full h-full object-cover group-hover:scale-[1.04] transition-transform duration-500" style={`object-position: ${member.pos}; filter: saturate(0.9);`} />
            </div>
            <div class="p-8">
              <h3 class="display-sm text-white mb-1">{member.name}</h3>
              <p class="label text-[var(--color-brand)] mb-4">{member.role}</p>
              <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">{member.desc}</p>
            </div>
          </div>
        ))}
      </div>

      <div class="reveal media-frame scroll-fade-scale">
        <img src={`${base}media/team-trio.webp`} alt="Tým Trampolín — Hugo, Dan a Vojta" loading="lazy" class="w-full max-h-[32rem] object-cover" style="object-position: center 30%;" />
      </div>

      <div class="mt-10 reveal">
        <a href={`${base}o-tymu/`} class="link-button">
          Více o týmu
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══ SPONSOR CTA ═══ -->
  <SponsorCTA headline={'Chcete být součástí\nnašeho příběhu?'} />

  <Footer />

  <style>
    @keyframes scrollPulse {
      0%, 100% { transform: scaleX(0.3); opacity: 0.5; }
      50% { transform: scaleX(1); opacity: 1; }
    }
    .stack-card { will-change: transform; }
  </style>

  <script>
    import '../scripts/hero-shader.ts';

    // Rotating hero word — clip-mask swap
    function initRotatingWord() {
      const el = document.getElementById('rotating-word');
      if (!el || (el as HTMLElement).dataset.rotInit) return;
      (el as HTMLElement).dataset.rotInit = '1';
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      const words = ['mění pravidla hry', 'tvoří budoucnost', 'posouvá demokracii', 'nastavuje standardy', 'skáče výš'];
      let i = 0;
      el.style.display = 'inline-block';
      el.style.transition = 'clip-path 0.45s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.3s';
      setInterval(() => {
        el.style.clipPath = 'inset(0 100% 0 0)';
        el.style.opacity = '0.4';
        setTimeout(() => {
          i = (i + 1) % words.length;
          el.textContent = words[i];
          el.style.clipPath = 'inset(0 0 0 0)';
          el.style.opacity = '1';
        }, 460);
      }, 3200);
    }
    initRotatingWord();
    document.addEventListener('astro:page-load', initRotatingWord);
  </script>
</BaseLayout>
