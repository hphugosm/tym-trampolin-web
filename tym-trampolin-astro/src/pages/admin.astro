---
// Interní dashboard — není v navigaci ani sitemapě, noindex.
// Data čte přes token-gated edge funkci (anon klíč data nevytáhne).
const FN_URL = 'https://vdvvcdikpquajfzxprnr.supabase.co/functions/v1/tt-admin';
---

<!DOCTYPE html>
<html lang="cs">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Admin — Tým Trampolín</title>
  <style>
    :root {
      --ink: #030814; --ink2: #071022; --ink3: #0c1830;
      --line: rgba(127,200,255,0.16); --line2: rgba(127,200,255,0.34);
      --brand: #4fc8ff; --brand2: #86dcff; --violet: #7d8bff; --gold: #ffc94a; --ok: #34d399;
      --txt: #edf4ff; --txt2: #93a9cc; --txt3: #5d7599;
      --mono: ui-monospace, 'JetBrains Mono', monospace;
    }
    * { box-sizing: border-box; }
    body {
      margin: 0; background: var(--ink); color: var(--txt);
      font-family: system-ui, -apple-system, sans-serif; line-height: 1.5;
      -webkit-font-smoothing: antialiased;
    }
    .wrap { max-width: 1100px; margin: 0 auto; padding: 40px 20px 80px; }
    h1 { font-size: 24px; letter-spacing: -0.02em; margin: 0 0 4px; }
    h2 { font-size: 13px; text-transform: uppercase; letter-spacing: 0.16em; color: var(--txt3);
         font-family: var(--mono); margin: 40px 0 14px; font-weight: 600; }
    .sub { color: var(--txt3); font-size: 13px; font-family: var(--mono); margin-bottom: 8px; }
    .gate { max-width: 420px; margin: 12vh auto 0; }
    input {
      width: 100%; padding: 12px 14px; background: transparent; color: var(--txt);
      border: 2px solid var(--line2); font-family: var(--mono); font-size: 14px; outline: none;
    }
    input:focus { border-color: var(--brand); }
    button {
      cursor: pointer; font-family: var(--mono); font-size: 13px; font-weight: 600;
      text-transform: uppercase; letter-spacing: 0.08em; padding: 11px 18px;
      background: var(--brand); color: var(--ink); border: 2px solid var(--brand);
      transition: background 0.15s, transform 0.15s;
    }
    button:hover { background: var(--brand2); border-color: var(--brand2); }
    button.ghost { background: transparent; color: var(--txt); border-color: var(--line2); }
    button.ghost:hover { border-color: var(--brand); color: var(--brand2); }
    .row { display: flex; gap: 10px; flex-wrap: wrap; align-items: center; }
    .err { color: #f472b6; font-size: 13px; margin-top: 10px; min-height: 18px; }
    .cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 1px;
             background: var(--line); border: 1px solid var(--line); }
    .card { background: var(--ink); padding: 18px 20px; }
    .card .num { font-family: var(--mono); font-size: 32px; font-weight: 700; letter-spacing: -0.03em; }
    .card .lbl { font-size: 12px; color: var(--txt3); margin-top: 4px; }
    .card.gold .num { color: var(--gold); }
    .bars { display: flex; flex-direction: column; gap: 8px; }
    .bar-row { display: grid; grid-template-columns: 190px 1fr 48px; gap: 12px; align-items: center; font-size: 13px; }
    .bar-row .name { color: var(--txt2); }
    .bar-track { height: 12px; background: var(--ink3); border: 1px solid var(--line); position: relative; }
    .bar-fill { height: 100%; background: var(--brand); }
    .bar-row .val { font-family: var(--mono); text-align: right; color: var(--txt); }
    .day-chart { display: flex; align-items: flex-end; gap: 3px; height: 120px; padding-top: 10px;
                 border-bottom: 1px solid var(--line); }
    .day-bar { flex: 1; background: var(--violet); min-height: 2px; position: relative; }
    .day-bar:hover { background: var(--brand); }
    .day-labels { display: flex; justify-content: space-between; font-size: 10px; color: var(--txt3);
                  font-family: var(--mono); margin-top: 6px; }
    table { width: 100%; border-collapse: collapse; font-size: 13px; }
    th, td { text-align: left; padding: 8px 10px; border-bottom: 1px solid var(--line); }
    th { color: var(--txt3); font-family: var(--mono); font-size: 11px; text-transform: uppercase;
         letter-spacing: 0.1em; font-weight: 600; }
    td.mono { font-family: var(--mono); color: var(--txt2); font-size: 12px; }
    .scroll { overflow-x: auto; border: 1px solid var(--line); }
    .hidden { display: none !important; }
    .subs-box { border: 1px solid var(--line); background: var(--ink2); padding: 16px; }
    textarea { width: 100%; height: 90px; background: var(--ink3); color: var(--txt2); border: 1px solid var(--line);
               font-family: var(--mono); font-size: 12px; padding: 10px; resize: vertical; }
    a.logout { color: var(--txt3); font-size: 12px; font-family: var(--mono); text-decoration: none; cursor: pointer; }
    a.logout:hover { color: var(--brand2); }
    .muted { color: var(--txt3); font-size: 12px; }
  </style>
</head>
<body data-fn={FN_URL}>
  <!-- BRÁNA -->
  <div id="gate" class="wrap gate">
    <h1>Admin dashboard</h1>
    <p class="sub">Zadej přístupový token.</p>
    <input id="token-input" type="password" placeholder="přístupový token" autocomplete="off" />
    <div class="row" style="margin-top:12px;">
      <button id="unlock">Odemknout</button>
    </div>
    <div class="err" id="gate-err"></div>
  </div>

  <!-- DASHBOARD -->
  <div id="dash" class="wrap hidden">
    <div class="row" style="justify-content:space-between;">
      <div>
        <h1>Tým Trampolín — přehled</h1>
        <p class="sub" id="generated">—</p>
      </div>
      <div class="row">
        <button class="ghost" id="refresh">Obnovit</button>
        <a class="logout" id="logout">Odhlásit</a>
      </div>
    </div>

    <div class="cards" id="cards" style="margin-top:20px;"></div>

    <h2>Události za posledních 30 dní</h2>
    <div class="day-chart" id="day-chart"></div>
    <div class="day-labels" id="day-labels"></div>

    <h2>Události podle typu</h2>
    <div class="bars" id="event-bars"></div>

    <h2>Odběratelé novinek</h2>
    <div class="subs-box">
      <div class="row" style="justify-content:space-between; margin-bottom:14px;">
        <span class="muted" id="subs-count">—</span>
        <div class="row">
          <button class="ghost" id="copy-emails">Kopírovat e-maily (BCC)</button>
          <button class="ghost" id="export-csv">Export CSV</button>
          <button id="compose">Napsat novinku →</button>
        </div>
      </div>
      <textarea id="subs-emails" readonly placeholder="Zatím žádní odběratelé."></textarea>
      <p class="muted" style="margin-top:10px;">
        Tip: „Napsat novinku" otevře e-mail s odběrateli v BCC. Pro větší seznamy zvaž službu Resend (viz poznámka v kódu).
      </p>
    </div>

    <h2>Poslední události</h2>
    <div class="scroll">
      <table>
        <thead><tr><th>Kdy</th><th>Událost</th><th>Stránka</th><th>Detail</th></tr></thead>
        <tbody id="recent-rows"></tbody>
      </table>
    </div>
  </div>

  <script>
    const FN = document.body.dataset.fn;
    const KEY = 'tt_admin_token_v1';

    const LABELS = {
      partner_cta_click: 'Kliknutí na partnerství',
      press_kit_download: 'Stažení press kitu',
      project_detail_view: 'Zobrazení projektu',
      external_game_click: 'Spuštění hry',
      sponsor_email_click: 'Kliknutí na e-mail',
      media_download_logo: 'Stažení loga',
      account_copy: 'Zkopírování účtu',
      newsletter_signup: 'Přihlášení k newsletteru',
      page_view: 'Zobrazení stránky',
    };
    const label = (n) => LABELS[n] || n;

    const $ = (id) => document.getElementById(id);
    const esc = (s) => String(s).replace(/[<>&"]/g, (c) => ({ '<': '&lt;', '>': '&gt;', '&': '&amp;', '"': '&quot;' }[c]));

    async function load(token) {
      const res = await fetch(FN, { method: 'POST', headers: { 'x-admin-token': token } });
      if (res.status === 401) throw new Error('Neplatný token.');
      if (!res.ok) throw new Error('Chyba serveru (' + res.status + ').');
      return res.json();
    }

    function fmtDate(iso) {
      const d = new Date(iso);
      return d.toLocaleString('cs-CZ', { day: '2-digit', month: '2-digit', hour: '2-digit', minute: '2-digit' });
    }

    function render(data) {
      $('generated').textContent = 'Aktualizováno: ' + fmtDate(data.generated_at);

      const byName = data.events_by_name || {};
      const totalEvents = data.total_events || 0;
      const partnerClicks = (byName.partner_cta_click || 0) + (byName.sponsor_email_click || 0);
      const cards = [
        { num: totalEvents, lbl: 'událostí celkem' },
        { num: partnerClicks, lbl: 'zájem o partnerství', gold: partnerClicks > 0 },
        { num: byName.external_game_click || 0, lbl: 'spuštění hry' },
        { num: (byName.press_kit_download || 0) + (byName.media_download_logo || 0), lbl: 'stažení materiálů' },
        { num: data.subscriber_count || 0, lbl: 'odběratelů', gold: (data.subscriber_count || 0) > 0 },
      ];
      $('cards').innerHTML = cards.map((c) =>
        '<div class="card' + (c.gold ? ' gold' : '') + '"><div class="num">' + c.num + '</div><div class="lbl">' + c.lbl + '</div></div>'
      ).join('');

      // graf po dnech
      const days = data.events_by_day || [];
      const max = Math.max(1, ...days.map((d) => d.count));
      $('day-chart').innerHTML = days.map((d) =>
        '<div class="day-bar" style="height:' + Math.round((d.count / max) * 100) + '%" title="' + d.day + ': ' + d.count + '"></div>'
      ).join('') || '<span class="muted">Zatím žádná data.</span>';
      $('day-labels').innerHTML = days.length
        ? '<span>' + days[0].day + '</span><span>' + days[days.length - 1].day + '</span>' : '';

      // podle typu
      const entries = Object.entries(byName).sort((a, b) => b[1] - a[1]);
      const maxN = Math.max(1, ...entries.map((e) => e[1]));
      $('event-bars').innerHTML = entries.map(([name, n]) =>
        '<div class="bar-row"><span class="name">' + esc(label(name)) + '</span>' +
        '<span class="bar-track"><span class="bar-fill" style="width:' + Math.round((n / maxN) * 100) + '%"></span></span>' +
        '<span class="val">' + n + '</span></div>'
      ).join('') || '<span class="muted">Zatím žádné události.</span>';

      // odběratelé
      const subs = data.subscribers || [];
      $('subs-count').textContent = subs.length + ' ' + (subs.length === 1 ? 'odběratel' : (subs.length >= 2 && subs.length <= 4 ? 'odběratelé' : 'odběratelů'));
      $('subs-emails').value = subs.map((s) => s.email).join(', ');
      window.__subs = subs;

      // poslední události
      $('recent-rows').innerHTML = (data.recent_events || []).map((e) => {
        const meta = e.meta && Object.keys(e.meta).length ? JSON.stringify(e.meta) : '';
        return '<tr><td class="mono">' + fmtDate(e.at) + '</td><td>' + esc(label(e.name)) +
          '</td><td class="mono">' + esc(e.path || '') + '</td><td class="mono">' + esc(meta) + '</td></tr>';
      }).join('') || '<tr><td colspan="4" class="muted">Zatím žádné události.</td></tr>';
    }

    async function boot(token) {
      try {
        const data = await load(token);
        localStorage.setItem(KEY, token);
        $('gate').classList.add('hidden');
        $('dash').classList.remove('hidden');
        render(data);
      } catch (e) {
        localStorage.removeItem(KEY);
        $('gate').classList.remove('hidden');
        $('dash').classList.add('hidden');
        $('gate-err').textContent = e.message;
      }
    }

    $('unlock').addEventListener('click', () => boot($('token-input').value.trim()));
    $('token-input').addEventListener('keydown', (e) => { if (e.key === 'Enter') boot($('token-input').value.trim()); });
    $('refresh').addEventListener('click', () => boot(localStorage.getItem(KEY) || ''));
    $('logout').addEventListener('click', () => { localStorage.removeItem(KEY); location.reload(); });

    $('copy-emails').addEventListener('click', () => {
      navigator.clipboard.writeText($('subs-emails').value).then(() => {
        $('copy-emails').textContent = 'Zkopírováno ✓';
        setTimeout(() => ($('copy-emails').textContent = 'Kopírovat e-maily (BCC)'), 1500);
      });
    });
    $('export-csv').addEventListener('click', () => {
      const subs = window.__subs || [];
      const csv = 'email,source,created_at\n' + subs.map((s) => s.email + ',' + s.source + ',' + s.at).join('\n');
      const a = document.createElement('a');
      a.href = URL.createObjectURL(new Blob([csv], { type: 'text/csv' }));
      a.download = 'odberatele-' + new Date().toISOString().slice(0, 10) + '.csv';
      a.click();
    });
    $('compose').addEventListener('click', () => {
      const emails = ($('subs-emails').value || '').trim();
      if (!emails) { alert('Zatím žádní odběratelé.'); return; }
      const subject = encodeURIComponent('Novinky od Týmu Trampolín');
      window.location.href = 'mailto:?bcc=' + encodeURIComponent(emails) + '&subject=' + subject;
    });

    // auto-login z uloženého tokenu
    const saved = localStorage.getItem(KEY);
    if (saved) boot(saved);
  </script>
</body>
</html>
