---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="404 — Stránka nenalezena">
  <Navigation />

  <section class="relative z-10 min-h-[70vh] flex items-center justify-center px-6">
    <div class="text-center">
      <div class="text-8xl font-bold text-gradient font-[var(--font-heading)] mb-4">404</div>
      <h1 class="text-2xl font-bold text-white mb-3">Stránka nenalezena</h1>
      <p class="text-[var(--color-text-secondary)] max-w-md mx-auto mb-8">
        Tahle stránka neexistuje nebo byla přesunuta. Zkuste se podívat jinam.
      </p>
      <div class="flex items-center justify-center gap-4">
        <a href={`${base}`} class="magnetic btn-primary" data-magnetic="14">
          Zpět domů
        </a>
        <a href={`${base}uspechy/`} class="magnetic btn-outline" data-magnetic="10">
          Naše úspěchy
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
