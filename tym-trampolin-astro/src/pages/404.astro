---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="404 — Stránka nenalezena">
  <Navigation />

  <section class="relative z-10 min-h-[85vh] flex items-center px-5 md:px-10">
    <div class="max-w-[80rem] mx-auto w-full">
      <div class="num-outline text-[clamp(8rem,30vw,24rem)]" style="-webkit-text-stroke-color: var(--color-brand);">404</div>
      <h1 class="display-md text-white mb-4">Stránka nenalezena</h1>
      <p class="text-[var(--color-text-secondary)] max-w-md mb-10">
        Tahle stránka neexistuje nebo byla přesunuta. Odrazte se zpátky.
      </p>
      <div class="flex flex-wrap items-center gap-4">
        <a href={`${base}`} class="magnetic btn-primary" data-magnetic="10">
          Zpátky na trampolínu
        </a>
        <a href={`${base}projekty/`} class="magnetic btn-outline" data-magnetic="8">
          Projekty
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
