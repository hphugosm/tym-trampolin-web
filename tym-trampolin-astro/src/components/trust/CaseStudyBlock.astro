---
// Case-study skeleton: challenge → solution → outcome → proof.
// Renders only the sections the project provides.

interface OutcomeMetric {
  value: string;
  label: string;
  context?: string;
}
interface ProofLink {
  href: string;
  label: string;
}

interface Props {
  challenge?: string;
  solution?: string;
  role?: string;
  teamMembers?: string[];
  outcomeMetrics?: OutcomeMetric[];
  proofLinks?: ProofLink[];
  awards?: string[];
  sponsorFit?: string[];
  updatedAt?: string;
}

const { challenge, solution, role, teamMembers, outcomeMetrics, proofLinks, awards, sponsorFit, updatedAt } = Astro.props;
import AsOfDate from './AsOfDate.astro';
import AwardBadge from './AwardBadge.astro';
---

<div class="space-y-10">
  {(challenge || solution) && (
    <div class="grid grid-cols-1 md:grid-cols-2 border border-[var(--color-line)] divide-y md:divide-y-0 md:divide-x divide-[var(--color-line)]">
      {challenge && (
        <div class="p-7 md:p-9">
          <p class="eyebrow mb-4">Výzva</p>
          <p class="text-[var(--color-text-secondary)] leading-relaxed">{challenge}</p>
        </div>
      )}
      {solution && (
        <div class="p-7 md:p-9">
          <p class="eyebrow mb-4">Řešení</p>
          <p class="text-[var(--color-text-secondary)] leading-relaxed">{solution}</p>
        </div>
      )}
    </div>
  )}

  {outcomeMetrics && outcomeMetrics.length > 0 && (
    <div>
      <p class="eyebrow mb-5">Měřitelné výsledky</p>
      <dl class="grid grid-cols-2 md:grid-cols-4 border border-[var(--color-line)] divide-x divide-[var(--color-line)]">
        {outcomeMetrics.map((m, i) => (
          <div class:list={['p-5 md:p-6', i >= 2 && 'border-t md:border-t-0 border-[var(--color-line)]']}>
            <dd class="stat-num !text-2xl md:!text-4xl text-white">{m.value}</dd>
            <dt class="label !text-[0.62rem] text-[var(--color-text-muted)] mt-2">{m.label}</dt>
            {m.context && <p class="text-xs text-[var(--color-text-muted)] mt-1">{m.context}</p>}
          </div>
        ))}
      </dl>
      {updatedAt && <div class="mt-3"><AsOfDate date={updatedAt} /></div>}
    </div>
  )}

  {awards && awards.length > 0 && (
    <div class="flex flex-wrap gap-3">
      {awards.map((a) => <AwardBadge award={a} />)}
    </div>
  )}

  {(role || (teamMembers && teamMembers.length > 0)) && (
    <div class="text-sm text-[var(--color-text-secondary)]">
      {role && <p><span class="label text-[var(--color-text-muted)]">Naše role:</span> {role}</p>}
      {teamMembers && teamMembers.length > 0 && (
        <p class="mt-1"><span class="label text-[var(--color-text-muted)]">Tým:</span> {teamMembers.join(', ')}</p>
      )}
    </div>
  )}

  {proofLinks && proofLinks.length > 0 && (
    <div>
      <p class="eyebrow mb-4">Důkazy & odkazy</p>
      <div class="flex flex-wrap gap-3">
        {proofLinks.map((l) => (
          <a href={l.href} target={l.href.startsWith('http') ? '_blank' : undefined} rel={l.href.startsWith('http') ? 'noopener noreferrer' : undefined} class="link-button">
            {l.label}
            <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/></svg>
          </a>
        ))}
      </div>
    </div>
  )}

  {sponsorFit && sponsorFit.length > 0 && (
    <div class="border-2 border-[var(--color-line-strong)] p-6 md:p-8">
      <p class="eyebrow mb-4">Proč je to zajímavé pro partnery</p>
      <ul class="space-y-2">
        {sponsorFit.map((s) => (
          <li class="flex items-start gap-3 text-sm text-[var(--color-text-secondary)]">
            <span class="text-[var(--color-brand)] shrink-0 mt-0.5" aria-hidden="true">✳</span>
            {s}
          </li>
        ))}
      </ul>
    </div>
  )}
</div>
