---
interface Props {
  file: string;
  label: string;
  size: string;
  type: string;
  trackEvent?: string;
  border?: boolean;
}
const base = import.meta.env.BASE_URL;
const { file, label, size, type, trackEvent = 'press_kit_download', border = false } = Astro.props;
---

<a
  href={`${base}press/${file}`}
  download
  data-track={trackEvent}
  data-track-meta={JSON.stringify({ file })}
  class:list={['group grid grid-cols-[3.5rem_1fr_auto] items-center gap-4 md:gap-8 px-5 md:px-10 py-5 no-underline hover:bg-[var(--color-ink-2)] transition-colors', border && 'border-t border-[var(--color-line)]']}
>
  <span class="label !text-[0.62rem] border border-[var(--color-line-strong)] text-[var(--color-brand)] py-1.5 text-center">{type}</span>
  <span>
    <span class="text-white font-medium group-hover:text-[var(--color-brand-hot)] transition-colors block">{label}</span>
    <span class="label !text-[0.62rem] text-[var(--color-text-muted)]">{file} &bull; {size}</span>
  </span>
  <svg class="text-[var(--color-text-muted)] group-hover:text-[var(--color-brand)] group-hover:translate-y-1 transition-all" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
</a>
