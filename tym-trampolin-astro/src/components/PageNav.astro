---
interface NavCard {
  href: string;
  label: string;
  title: string;
  desc: string;
  icon?: string;
}
interface Props {
  cards: NavCard[];
}
const { cards } = Astro.props;
---

<section class="relative z-10 mt-24 rule">
  <div class="max-w-[80rem] mx-auto px-5 md:px-10 py-4">
    <p class="label text-[var(--color-text-muted)] py-4">Prozkoumejte dál</p>
  </div>
  <div class="rule">
    <div class={`max-w-[80rem] mx-auto grid grid-cols-1 ${cards.length === 2 ? 'sm:grid-cols-2' : 'sm:grid-cols-3'}`}>
      {cards.map((card, i) => (
        <a
          href={card.href}
          class:list={[
            'group flex items-end justify-between gap-6 p-8 md:p-10 min-h-[11rem] no-underline transition-colors hover:bg-[var(--color-ink-2)]',
            i > 0 && 'border-t sm:border-t-0 sm:border-l border-[var(--color-line)]',
          ]}
        >
          <div class="min-w-0">
            <div class="eyebrow mb-3">{card.label}</div>
            <div class="display-sm text-white group-hover:text-[var(--color-brand-hot)] transition-colors">
              {card.title}
            </div>
            <div class="text-sm text-[var(--color-text-muted)] mt-2">{card.desc}</div>
          </div>
          <svg
            class="shrink-0 mb-1 text-[var(--color-text-muted)] group-hover:text-[var(--color-brand)] group-hover:translate-x-2 transition-all duration-300"
            width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"
          >
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      ))}
    </div>
  </div>
</section>
