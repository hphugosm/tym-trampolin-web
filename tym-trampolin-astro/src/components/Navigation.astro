---
interface Props {
  active?: string;
}

const { active } = Astro.props;
const base = import.meta.env.BASE_URL;

const links = [
  { href: `${base}`, label: 'Domů', id: 'home' },
  { href: `${base}o-tymu/`, label: 'O týmu', id: 'o-tymu' },
  { href: `${base}projekty/`, label: 'Projekty', id: 'projekty' },
  { href: `${base}uspechy/`, label: 'Úspěchy', id: 'uspechy' },
  { href: `${base}galerie/`, label: 'Galerie', id: 'galerie' },
  { href: `${base}pro-media/`, label: 'Pro média', id: 'pro-media' },
  { href: `${base}podpora/`, label: 'Podpora', id: 'podpora' },
  { href: `${base}music/`, label: 'Hudba', id: 'music' },
];
---

<nav id="main-nav" class="fixed top-0 left-0 right-0 z-50 glass-over-media" transition:name="main-nav">
  <div class="max-w-[80rem] mx-auto px-5 md:px-10 h-16 flex items-center justify-between">
    <!-- Brand -->
    <a href={`${base}`} class="flex items-center gap-2.5 no-underline group shrink-0">
      <svg width="26" height="26" viewBox="0 0 64 64" aria-hidden="true">
        <rect width="64" height="64" rx="10" fill="var(--color-ink-3)"/>
        <path d="M9 13h21v7.5h-6.5V40H15V20.5H9z" fill="var(--color-brand)"/>
        <path d="M34 13h21v7.5h-6.5V40H40V20.5h-6z" fill="var(--color-brand)"/>
        <path d="M10 47q22 12 44 0" stroke="var(--color-accent-2)" stroke-width="4" fill="none" stroke-linecap="round"/>
        <circle cx="47" cy="42" r="4" fill="var(--color-gold)"/>
      </svg>
      <span class="label text-white group-hover:text-[var(--color-brand-hot)] transition-colors">
        Tým Trampolín
      </span>
    </a>

    <!-- Desktop Nav -->
    <div class="hidden lg:flex items-center gap-0.5">
      {links.map((link) => (
        <a
          href={link.href}
          aria-current={active === link.id ? 'page' : undefined}
          class:list={[
            'nav-link label relative px-3 py-2 no-underline transition-colors duration-200',
            active === link.id
              ? 'text-white active'
              : 'text-[var(--color-text-muted)] hover:text-white'
          ]}
        >
          {link.label}
        </a>
      ))}
      <a href={`${base}partnerstvi/`} data-track="partner_cta_click" data-track-meta='{"placement":"nav"}' class:list={['magnetic btn-primary ml-4 !py-2 !px-4 !text-[0.7rem]', active === 'partnerstvi' && 'outline outline-2 outline-offset-2 outline-[var(--color-brand)]']} data-magnetic="8">
        Partnerství
      </a>
    </div>

    <!-- Mobile Toggle -->
    <button id="nav-toggle" class="lg:hidden w-11 h-11 flex flex-col items-center justify-center gap-1.5 text-white z-[70]" aria-label="Menu" aria-expanded="false">
      <span class="nav-line w-6 h-[2px] bg-current transition-all duration-300"></span>
      <span class="nav-line w-6 h-[2px] bg-current transition-all duration-300"></span>
    </button>
  </div>
</nav>

<!-- Full-screen mobile menu -->
<div id="mobile-menu" class="lg:hidden fixed inset-0 z-[60] hidden" aria-hidden="true">
  <div class="absolute inset-0 bg-[var(--color-ink)]"></div>
  <div class="relative h-full flex flex-col justify-center px-8 gap-1 overflow-y-auto py-24">
    {links.map((link, i) => (
      <a
        href={link.href}
        class:list={[
          'mobile-link display-sm no-underline py-1.5 transition-colors',
          active === link.id ? 'text-[var(--color-brand)]' : 'text-white hover:text-[var(--color-brand-hot)]'
        ]}
        style={`--i:${i}`}
      >
        <span class="label text-[var(--color-text-muted)] mr-4">0{i + 1}</span>{link.label}
      </a>
    ))}
    <a href={`${base}partnerstvi/`} data-track="partner_cta_click" data-track-meta='{"placement":"nav-mobile"}' class="btn-primary mt-8 self-start">Partnerství</a>
  </div>
</div>

<style>
  .nav-link::after {
    content: '';
    position: absolute;
    left: 0.75rem;
    right: 0.75rem;
    bottom: 0;
    height: 2px;
    background: var(--color-brand);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.25s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .nav-link:hover::after,
  .nav-link.active::after { transform: scaleX(1); }

  #nav-toggle.active .nav-line:nth-child(1) { transform: translateY(4px) rotate(45deg); }
  #nav-toggle.active .nav-line:nth-child(2) { transform: translateY(-4px) rotate(-45deg); }

  #mobile-menu .mobile-link {
    opacity: 0;
    transform: translateY(20px);
  }
  #mobile-menu.open .mobile-link {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.4s cubic-bezier(0.22, 1, 0.36, 1), transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: calc(var(--i) * 55ms + 80ms);
  }

  @media (prefers-reduced-motion: reduce) {
    #mobile-menu .mobile-link { opacity: 1; transform: none; transition: none; }
  }
</style>

<script>
  function initNav() {
    const toggle = document.getElementById('nav-toggle');
    const menu = document.getElementById('mobile-menu');
    if (!toggle || !menu || toggle.dataset.navInit) return;
    toggle.dataset.navInit = '1';
    toggle.addEventListener('click', () => {
      const isOpen = menu.classList.contains('open');
      if (isOpen) {
        menu.classList.remove('open');
        setTimeout(() => menu.classList.add('hidden'), 250);
      } else {
        menu.classList.remove('hidden');
        requestAnimationFrame(() => requestAnimationFrame(() => menu.classList.add('open')));
      }
      toggle.classList.toggle('active', !isOpen);
      toggle.setAttribute('aria-expanded', String(!isOpen));
      menu.setAttribute('aria-hidden', String(isOpen));
      document.body.style.overflow = isOpen ? '' : 'hidden';
    });
    menu.querySelectorAll('a').forEach((a) =>
      a.addEventListener('click', () => {
        document.body.style.overflow = '';
      })
    );
  }
  initNav();
  document.addEventListener('astro:page-load', initNav);
</script>
