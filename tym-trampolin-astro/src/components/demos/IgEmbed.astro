---
// Instagram záznamy — pokud jsou permalinky, vykreslí karty; jinak profil placeholder.
interface Props {
  posts: { url: string; caption?: string }[];
  profile?: string;
  accent?: string;
}
const { posts, profile = 'https://www.instagram.com/tym_trampolin/', accent = 'var(--color-gold)' } = Astro.props;
---
{posts.length > 0 ? (
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    {posts.map((p) => (
      <a
        href={p.url}
        target="_blank"
        rel="noopener noreferrer"
        class="glass card-hover p-5 flex flex-col gap-3 no-underline"
        style={`border-top: 2px solid ${accent};`}
      >
        <div class="flex items-center gap-2">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke={accent} stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill={accent} stroke="none"/></svg>
          <span class="label text-white">@tym_trampolin</span>
        </div>
        {p.caption && <p class="text-sm text-[var(--color-text-secondary)]">{p.caption}</p>}
        <span class="link-button !text-[0.68rem] mt-auto">Otevřít na Instagramu</span>
      </a>
    ))}
  </div>
) : (
  <div class="glass-strong p-8 flex flex-col items-center text-center gap-4" style={`border-top: 2px solid ${accent};`}>
    <svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke={accent} stroke-width="1.6"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill={accent} stroke="none"/></svg>
    <p class="text-[var(--color-text-secondary)] max-w-md">
      AI-editované záznamy ze soutěže (titulky a střih přidané AI) publikujeme na Instagramu týmu.
    </p>
    <a href={profile} target="_blank" rel="noopener noreferrer" class="btn-outline">@tym_trampolin na Instagramu</a>
    <p class="label !text-[0.58rem] text-[var(--color-text-muted)]">Konkrétní příspěvky sem doplníme jako embedy, až budou permalinky.</p>
  </div>
)}
