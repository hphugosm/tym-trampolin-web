---
import type { Accent } from '../../types/dashboard';
import { ACCENT_VAR } from '../../data/dashboard/modules';

interface Props { value: number; max: number; label?: string; accent?: Accent; unit?: string; }
const { value, max, label, accent = 'gold', unit = '' } = Astro.props;
const frac = Math.max(0, Math.min(1, value / (max || 1)));
const R = 52, C = Math.PI * R; // půlkruh
const dash = frac * C;
const c = ACCENT_VAR[accent];
---
<div class="flex flex-col items-center">
  <svg viewBox="0 0 140 80" width="180" class="block" aria-hidden="true">
    <path d={`M 18 74 A ${R} ${R} 0 0 1 122 74`} fill="none" stroke="var(--color-ink-3)" stroke-width="12" stroke-linecap="round" />
    <path d={`M 18 74 A ${R} ${R} 0 0 1 122 74`} fill="none" stroke={c} stroke-width="12" stroke-linecap="round"
      stroke-dasharray={`${dash} ${C}`} />
  </svg>
  <div class="dash-mono text-2xl font-bold text-white -mt-4">{value.toLocaleString('cs-CZ')}{unit}</div>
  <div class="dash-muted text-xs mt-0.5">{label ?? `z ${max.toLocaleString('cs-CZ')}${unit}`}</div>
</div>
