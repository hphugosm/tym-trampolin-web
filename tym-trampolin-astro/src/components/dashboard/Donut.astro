---
import type { BarItem } from '../../types/dashboard';
import { ACCENT_VAR } from '../../data/dashboard/modules';

interface Props { items: BarItem[]; unit?: string; size?: number; }
const { items, unit = '', size = 150 } = Astro.props;
const total = items.reduce((s, i) => s + i.value, 0) || 1;
const R = 54, C = 2 * Math.PI * R;
let offset = 0;
const segs = items.map((it) => {
  const frac = it.value / total;
  const seg = { color: ACCENT_VAR[it.accent || 'cyan'], dash: frac * C, offset: -offset * C, label: it.label, value: it.value };
  offset += frac;
  return seg;
});
---
<div class="flex items-center gap-5 flex-wrap">
  <svg viewBox="0 0 140 140" width={size} height={size} class="shrink-0 -rotate-90" aria-hidden="true">
    <circle cx="70" cy="70" r={R} fill="none" stroke="var(--color-ink-3)" stroke-width="16" />
    {segs.map((s) => (
      <circle cx="70" cy="70" r={R} fill="none" stroke={s.color} stroke-width="16"
        stroke-dasharray={`${s.dash} ${C - s.dash}`} stroke-dashoffset={s.offset} />
    ))}
  </svg>
  <ul class="flex flex-col gap-1.5 text-sm min-w-0">
    {items.map((it) => (
      <li class="flex items-center gap-2">
        <span class="w-2.5 h-2.5 shrink-0" style={`background:${ACCENT_VAR[it.accent || 'cyan']};`}></span>
        <span class="text-[var(--color-text-secondary)] truncate">{it.label}</span>
        <span class="dash-mono text-white ml-auto pl-2">{it.value}{unit}</span>
      </li>
    ))}
  </ul>
</div>
