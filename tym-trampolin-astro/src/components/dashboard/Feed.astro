---
import type { FeedItem } from '../../types/dashboard';
import { ACCENT_VAR } from '../../data/dashboard/modules';

interface Props { items: FeedItem[]; id?: string; }
const { items, id } = Astro.props;
const fmt = (iso: string) => new Date(iso).toLocaleString('cs-CZ', { day: '2-digit', month: '2-digit', hour: '2-digit', minute: '2-digit' });
---
<ul class="flex flex-col" data-feed={id}>
  {items.length === 0 && <li class="dash-muted text-sm py-2">Zatím žádná aktivita.</li>}
  {items.map((it, i) => (
    <li class:list={['flex items-start gap-3 py-2.5', i > 0 && 'border-t border-[var(--color-line)]']}>
      <span class="w-1.5 h-1.5 rounded-full mt-1.5 shrink-0" style={`background:${ACCENT_VAR[it.accent || 'cyan']};`}></span>
      <div class="min-w-0 flex-1">
        <div class="text-sm text-[var(--color-text-secondary)]">{it.text}</div>
        <div class="dash-mono text-[10px] text-[var(--color-text-muted)] mt-0.5">{it.kind} · {fmt(it.at)}</div>
      </div>
    </li>
  ))}
</ul>
