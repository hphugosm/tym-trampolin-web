---
const base = import.meta.env.BASE_URL;
const year = new Date().getFullYear();

const navLinks = [
  { href: `${base}`, label: 'Domů' },
  { href: `${base}o-tymu/`, label: 'O týmu' },
  { href: `${base}projekty/`, label: 'Projekty' },
  { href: `${base}uspechy/`, label: 'Úspěchy' },
  { href: `${base}galerie/`, label: 'Galerie' },
  { href: `${base}music/`, label: 'Hudba' },
  { href: `${base}podpora/`, label: 'Podpora' },
  { href: `${base}kontakt/`, label: 'Kontakt' },
];

const partnerLinks = [
  { href: `${base}partnerstvi/`, label: 'Partnerství', track: 'partner_cta_click' },
  { href: `${base}pro-media/`, label: 'Pro média' },
  { href: `${base}psali-o-nas/`, label: 'Psali o nás' },
];

const legalLinks = [
  { href: `${base}privacy/`, label: 'Soukromí' },
  { href: `${base}cookies/`, label: 'Cookies' },
  { href: `${base}pristupnost/`, label: 'Přístupnost' },
];
---

<footer class="relative z-10 mt-32 rule-strong bg-[var(--color-ink-2)]">
  <!-- Giant wordmark -->
  <div class="max-w-[80rem] mx-auto px-5 md:px-10 pt-16 pb-8 overflow-hidden">
    <a href={`${base}`} class="block no-underline" aria-label="Tým Trampolín — domů">
      <span class="display-xl block text-white/[0.92] hover:text-[var(--color-brand)] transition-colors duration-300 whitespace-nowrap">
        Tým Trampolín
      </span>
    </a>
  </div>

  <!-- CTA row -->
  <div class="rule">
    <div class="max-w-[80rem] mx-auto px-5 md:px-10 py-10 flex flex-col md:flex-row md:items-center justify-between gap-6">
      <div>
        <p class="eyebrow mb-2">Novinky</p>
        <p class="text-[var(--color-text-secondary)] max-w-md">
          Chcete vědět o nových projektech jako první? Napište si o novinky — žádný spam, jen to podstatné.
        </p>
      </div>
      <div class="flex flex-wrap items-center gap-4">
        <form id="newsletter-form" class="flex flex-col sm:flex-row gap-3 w-full sm:w-auto" novalidate>
          <label for="newsletter-email" class="sr-only">Váš e-mail</label>
          <input
            id="newsletter-email"
            type="email"
            name="email"
            required
            autocomplete="email"
            placeholder="vas@email.cz"
            class="w-full sm:w-64 px-4 py-3 bg-transparent border-2 border-[var(--color-line-strong)] text-white placeholder:text-[var(--color-text-muted)] text-sm font-[var(--font-mono)] outline-none focus:border-[var(--color-brand)] transition-colors"
          />
          <input type="text" name="website" tabindex="-1" autocomplete="off" aria-hidden="true" class="hidden" />
          <button type="submit" class="btn-primary whitespace-nowrap">
            Odebírat novinky
          </button>
        </form>
        <p id="newsletter-msg" class="label !text-[0.68rem] w-full hidden" role="status" aria-live="polite"></p>
        <a href="https://www.instagram.com/tym_trampolin/" target="_blank" rel="noopener noreferrer" class="w-11 h-11 border-2 border-[var(--color-line-strong)] hover:border-[var(--color-brand)] hover:text-[var(--color-brand-hot)] flex items-center justify-center text-[var(--color-text-secondary)] transition-colors" aria-label="Instagram">
          <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
        </a>
        <a href="https://www.twitch.tv/tym_trampolin" target="_blank" rel="noopener noreferrer" class="w-11 h-11 border-2 border-[var(--color-line-strong)] hover:border-[var(--color-brand)] hover:text-[var(--color-brand-hot)] flex items-center justify-center text-[var(--color-text-secondary)] transition-colors" aria-label="Twitch">
          <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M11.571 4.714h1.715v5.143H11.57zm4.715 0H18v5.143h-1.714zM6 0L1.714 4.286v15.428h5.143V24l4.286-4.286h3.428L22.286 12V0zm14.571 11.143l-3.428 3.428h-3.429l-3 3v-3H6.857V1.714h13.714z"/></svg>
        </a>
      </div>
    </div>
  </div>

  <!-- Link columns -->
  <div class="rule">
    <div class="max-w-[80rem] mx-auto px-5 md:px-10 py-12 grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-8">
      <div>
        <h4 class="label text-[var(--color-text-muted)] mb-4">Kdo jsme</h4>
        <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed max-w-xs">
          Studentský tým na průniku politiky, technologií a umělé inteligence. 3. místo DemocraTICon 2026.
        </p>
      </div>
      <div>
        <h4 class="label text-[var(--color-text-muted)] mb-4">Navigace</h4>
        <div class="grid grid-cols-2 gap-x-6 gap-y-2.5">
          {navLinks.map((link) => (
            <a href={link.href} class="link-underline text-sm text-[var(--color-text-secondary)] hover:text-white transition-colors w-fit">{link.label}</a>
          ))}
        </div>
      </div>
      <div>
        <h4 class="label text-[var(--color-text-muted)] mb-4">Partneři & média</h4>
        <div class="flex flex-col gap-2.5 mb-6">
          {partnerLinks.map((link) => (
            <a href={link.href} data-track={link.track} data-track-meta={link.track ? '{"placement":"footer"}' : undefined} class="link-underline text-sm text-[var(--color-text-secondary)] hover:text-white transition-colors w-fit">{link.label}</a>
          ))}
        </div>
        <h4 class="label text-[var(--color-text-muted)] mb-4">Kontakt</h4>
        <div class="flex flex-col gap-2.5">
          <a href="mailto:hugo.kubicek@icloud.com" class="link-underline text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-brand-hot)] transition-colors w-fit font-[var(--font-mono)]">
            hugo.kubicek@icloud.com
          </a>
          <a href="tel:+420731544015" class="link-underline text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-brand-hot)] transition-colors w-fit font-[var(--font-mono)]">
            +420 731 544 015
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom -->
  <div class="rule">
    <div class="max-w-[80rem] mx-auto px-5 md:px-10 py-6 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="label text-[var(--color-text-muted)]">
        &copy; {year} Tým Trampolín &mdash; Gymnázium Amazon, Praha
      </p>
      <div class="flex items-center gap-5">
        {legalLinks.map((link) => (
          <a href={link.href} class="label !text-[0.62rem] text-[var(--color-text-muted)] hover:text-white transition-colors no-underline">{link.label}</a>
        ))}
      </div>
      <p class="label text-[var(--color-text-muted)]">
        Politika &times; Technologie &times; AI
      </p>
    </div>
  </div>
</footer>

<script>
  import { SUPABASE_URL, SUPABASE_KEY, track } from '../scripts/track';

  function initNewsletter() {
    const form = document.getElementById('newsletter-form') as HTMLFormElement | null;
    const input = document.getElementById('newsletter-email') as HTMLInputElement | null;
    const msg = document.getElementById('newsletter-msg');
    if (!form || !input || !msg || form.dataset.nlInit) return;
    form.dataset.nlInit = '1';

    function say(text: string, ok: boolean) {
      msg!.textContent = text;
      msg!.classList.remove('hidden');
      msg!.style.color = ok ? 'var(--color-emerald)' : 'var(--color-rose)';
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const honeypot = (form.elements.namedItem('website') as HTMLInputElement | null)?.value;
      if (honeypot) return; // bot
      const email = input.value.trim();
      if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        say('Zadejte prosím platný e-mail.', false);
        input.focus();
        return;
      }
      try {
        const res = await fetch(`${SUPABASE_URL}/rest/v1/tt_subscribers`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            apikey: SUPABASE_KEY,
            Authorization: `Bearer ${SUPABASE_KEY}`,
            Prefer: 'return=minimal',
          },
          body: JSON.stringify({ email, source: 'web-footer' }),
        });
        if (res.status === 409) {
          say('Tenhle e-mail už novinky odebírá. Díky!', true);
          form.reset();
          return;
        }
        if (!res.ok) throw new Error(String(res.status));
        form.reset();
        say('Hotovo! O novém projektu se dozvíte jako první.', true);
        track('newsletter_signup', { source: 'web-footer' });
      } catch {
        say('Něco se pokazilo. Zkuste to prosím znovu, nebo nám napište e-mail.', false);
      }
    });
  }

  initNewsletter();
  document.addEventListener('astro:page-load', initNewsletter);
</script>
