---
interface Props {
  label?: string;
  title: string;
  description?: string;
  center?: boolean;
  index?: string;
}

const { label, title, description, center = true, index } = Astro.props;
---

<div class:list={['mb-12', center && 'text-center']}>
  {label && (
    <div class:list={['flex items-baseline gap-3 mb-4', center && 'justify-center']}>
      {index && <span class="label text-[var(--color-text-muted)]">{index}</span>}
      <span class="eyebrow">{label}</span>
    </div>
  )}
  <h2 class="display-md text-white" set:html={title} />
  {description && (
    <p class="mt-5 text-[var(--color-text-secondary)] max-w-2xl leading-relaxed" class:list={[center && 'mx-auto']}>
      {description}
    </p>
  )}
</div>
